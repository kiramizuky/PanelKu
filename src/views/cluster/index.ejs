<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">Cluster & Multi-Node Manager</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Manage and monitor secondary Agent Nodes from this Master dashboard</p>
  </div>
  <button class="btn-lp btn-lp-primary" onclick="ClusterPage.showAddModal()"><i class="bi bi-diagram-3-fill me-2"></i>Add Agent Node</button>
</div>

<div class="row g-4" id="nodesContainer">
  <!-- Dynamic node cards will go here -->
  <div class="col-12 text-center" style="padding:40px; color:var(--text-muted);">
    <i class="bi bi-diagram-3" style="font-size: 40px; display:block; margin-bottom:10px;"></i>
    Loading agent nodes...
  </div>
</div>

<!-- Add Node Modal -->
<div class="modal fade" id="addNodeModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border: 1px solid rgba(255,255,255,0.1); background: rgba(20,20,25,0.95);">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);">
        <h5 class="modal-title font-mono text-white" style="font-size:15px;">Add Secondary Agent Node</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="addNodeForm" onsubmit="ClusterPage.addNode(event)">
        <div class="modal-body">
          <div class="lp-form-group">
            <label class="lp-label">Node Identifier / Name</label>
            <input type="text" id="nodeName" class="lp-input" placeholder="e.g. Singapore-Edge-01" required>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">IP Address / Domain Name</label>
            <input type="text" id="nodeIp" class="lp-input" placeholder="e.g. 192.168.1.50" required>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Port</label>
            <input type="number" id="nodePort" class="lp-input" value="23456" placeholder="23456" required>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">API Key / Secret Token</label>
            <input type="password" id="nodeApiKey" class="lp-input" placeholder="Get from Agent Profile settings" required>
          </div>
        </div>
        <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary">Add Node</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/cluster.js"></script>
