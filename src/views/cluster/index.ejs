<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">Cluster &amp; Multi-Node Manager</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Manage and monitor secondary Agent Nodes from this Master dashboard</p>
  </div>
  <button class="btn-lp btn-lp-primary" onclick="ClusterPage.showAddModal()"><i class="bi bi-diagram-3-fill me-2"></i>Add Agent Node</button>
</div>

<div class="row g-4" id="nodesContainer">
  <!-- Dynamic node cards will go here -->
  <div class="col-12 text-center" style="padding:40px; color:var(--text-muted);">
    <i class="bi bi-diagram-3" style="font-size: 40px; display:block; margin-bottom:10px;"></i>
    Loading agent nodes...
  </div>
</div>

<!-- Add Node Modal -->
<div class="modal fade" id="addNodeModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border: 1px solid rgba(255,255,255,0.1); background: rgba(20,20,25,0.95);">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);">
        <h5 class="modal-title font-mono text-white" style="font-size:15px;"><i class="bi bi-diagram-3 me-2 text-primary"></i>Add Agent Node</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="addNodeForm" onsubmit="ClusterPage.addNode(event)">
        <div class="modal-body" style="display:flex; flex-direction:column; gap:14px;">
          <div class="lp-form-group" style="margin:0;">
            <label class="lp-label">Node Identifier / Name</label>
            <input type="text" id="nodeName" class="lp-input" placeholder="e.g. Singapore-Edge-01" required>
          </div>
          <div class="lp-form-group" style="margin:0;">
            <label class="lp-label">IP Address / Domain Name</label>
            <input type="text" id="nodeIp" class="lp-input" placeholder="e.g. 192.168.1.50 or node.example.com" required>
          </div>
          <div class="lp-form-group" style="margin:0;">
            <label class="lp-label">Port <span style="color:var(--text-muted); font-weight:400;">(opsional — kosongkan jika domain sudah mengarah langsung)</span></label>
            <input type="number" id="nodePort" class="lp-input" value="" placeholder="e.g. 23456 (kosongkan untuk port default 443/HTTPS)">
            <small style="color:var(--text-muted); font-size:11px; margin-top:4px; display:block;">
              <i class="bi bi-info-circle me-1"></i>
              Jika server sudah di-pointing ke domain tanpa port (melalui reverse proxy), kosongkan field ini agar menggunakan HTTPS otomatis.
            </small>
          </div>
          <div class="lp-form-group" style="margin:0;">
            <label class="lp-label">API Key / Secret Token</label>
            <div style="position:relative;">
              <input type="password" id="nodeApiKey" class="lp-input" placeholder="Get from Agent → Profile → API Key" required style="padding-right:42px;">
              <button type="button" onclick="ClusterPage.toggleApiKeyVis()" style="position:absolute; right:10px; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--text-muted); cursor:pointer; padding:0;" title="Show/Hide">
                <i class="bi bi-eye" id="apiKeyEyeIcon"></i>
              </button>
            </div>
          </div>
        </div>
        <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary"><i class="bi bi-plus-lg me-1"></i>Add Node</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/cluster.js?v=<%= Date.now() %>"></script>
