<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">SSL Certificates</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Manage Let's Encrypt certificates for domains</p>
  </div>
  <button class="btn-lp btn-lp-primary" onclick="SSLPage.showIssueModal()"><i class="bi bi-shield-lock"></i> Issue Certificate</button>
</div>

<div class="lp-glass-card" style="padding:0;overflow-x:auto;">
  <table class="lp-table">
    <thead>
      <tr>
        <th>Domain</th>
        <th>Provider</th>
        <th>Expires At</th>
        <th>Status</th>
        <th style="text-align:right">Actions</th>
      </tr>
    </thead>
    <tbody id="sslTableBody">
      <tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
    </tbody>
  </table>
</div>

<!-- Issue SSL Modal -->
<div class="modal fade" id="issueSslModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px">Issue Let's Encrypt SSL</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="issueSslForm" onsubmit="SSLPage.issueCertificate(event)">
        <div class="modal-body">
          <div class="lp-form-group">
            <label class="lp-label">Select Website</label>
            <select id="sslWebsiteId" class="lp-input" required>
              <option value="">Loading websites...</option>
            </select>
          </div>
          <p style="font-size:12px;color:var(--text-muted)">
            This will download and install `acme.sh` if it's not already installed. It uses the Webroot method, so ensure the domain is resolving to this server's IP address.
          </p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary">Issue</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/ssl.js"></script>
