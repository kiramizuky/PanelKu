<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">Website Management</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Manage domains, vhosts, and runtimes</p>
  </div>
  <button class="btn-lp btn-lp-primary" onclick="WebsitesPage.showCreateModal()"><i class="bi bi-plus-lg"></i> Add Website</button>
</div>

<div class="lp-glass-card" style="padding:0;overflow-x:auto;">
  <table class="lp-table">
    <thead>
      <tr>
        <th>Domain</th>
        <th>Status</th>
        <th>Type</th>
        <th>Directory / Port</th>
        <th>SSL</th>
        <th style="text-align:right">Actions</th>
      </tr>
    </thead>
    <tbody id="websitesTableBody">
      <tr><td colspan="6" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
    </tbody>
  </table>
  <div id="websitesPagination" style="padding: 0 15px 15px 15px;"></div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createWebsiteModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px">Create Website</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="createWebsiteForm" onsubmit="WebsitesPage.createWebsite(event)">
        <div class="modal-body">
          <div class="lp-form-group">
            <label class="lp-label">Domain Name</label>
            <input type="text" id="cwDomain" class="lp-input" placeholder="example.com" required>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Website Type</label>
            <select id="cwType" class="lp-input" required onchange="WebsitesPage.toggleTypeFields()">
              <option value="static">Static HTML</option>
              <option value="proxy">Reverse Proxy / Node.js</option>
              <option value="php">PHP</option>
            </select>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Document Root</label>
            <input type="text" id="cwRoot" class="lp-input" placeholder="/var/www/example.com">
            <div style="font-size:11px;color:var(--text-muted);margin-top:4px">Leave empty for default</div>
          </div>
          <div class="lp-form-group" id="cwPortGroup" style="display:none">
            <label class="lp-label">Proxy Target Port</label>
            <input type="number" id="cwPort" class="lp-input" placeholder="8080">
          </div>
          <div class="lp-form-group" id="cwPhpGroup" style="display:none">
            <label class="lp-label">PHP Version</label>
            <select id="cwPhpVersion" class="lp-input">
              <option value="8.0">PHP 8.0</option>
              <option value="8.1">PHP 8.1</option>
              <option value="8.2" selected>PHP 8.2</option>
              <option value="8.3">PHP 8.3</option>
            </select>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Git Repository (Optional)</label>
            <input type="text" id="cwGitRepo" class="lp-input" placeholder="https://github.com/user/repo.git">
          </div>
          <div class="lp-form-group" style="display:flex;align-items:center;gap:10px;">
            <input type="checkbox" id="cwAutoDeploy" style="accent-color:var(--primary-color)">
            <label class="lp-label" style="margin:0;cursor:pointer" for="cwAutoDeploy">Enable Auto Deploy via Webhook</label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary">Create Website</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/websites.js"></script>
