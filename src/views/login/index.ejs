<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Linux Panel</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
      background-image: url('/images/bg.png');
      background-size: cover;
      background-position: center;
    }
    .login-card {
      width: 100%;
      max-width: 400px;
      background: var(--glass-bg);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      padding: 40px 30px;
      box-shadow: var(--glass-shadow);
      color: #fff;
    }
  </style>
</head>
<body>

  <div class="login-card">
    <div class="text-center mb-4">
      <img src="/images/logo.png" alt="Panelku Logo" style="width: 54px; height: 54px; border-radius: 12px; object-fit: cover; box-shadow: 0 4px 15px rgba(0,0,0,0.6); margin-bottom: 15px;">
      <h2 style="font-weight:700; font-size:1.5rem; margin-bottom:5px;">Welcome Back</h2>
      <p style="color:var(--text-muted); font-size:0.9rem;">Sign in to your Linux Panel</p>
    </div>

    <form id="loginForm">
      <div id="errorMsg" class="alert alert-danger" style="display:none; background:rgba(239, 68, 68, 0.2); color:#fca5a5; border:1px solid rgba(239, 68, 68, 0.3); font-size:13px; padding:10px;"></div>
      
      <div class="lp-form-group mb-3">
        <label class="lp-label">Username</label>
        <div class="input-group">
          <span class="input-group-text" style="background:rgba(0,0,0,0.3); border:1px solid var(--glass-border); color:var(--text-muted); border-right:none;"><i class="bi bi-person"></i></span>
          <input type="text" id="username" class="form-control" style="background:rgba(0,0,0,0.3); border:1px solid var(--glass-border); color:#fff; border-left:none;" required>
        </div>
      </div>
      
      <div class="lp-form-group mb-4">
        <label class="lp-label">Password</label>
        <div class="input-group">
          <span class="input-group-text" style="background:rgba(0,0,0,0.3); border:1px solid var(--glass-border); color:var(--text-muted); border-right:none;"><i class="bi bi-lock"></i></span>
          <input type="password" id="password" class="form-control" style="background:rgba(0,0,0,0.3); border:1px solid var(--glass-border); color:#fff; border-left:none;" required>
        </div>
      </div>

      <button type="submit" class="btn-lp btn-lp-primary w-100" style="padding:10px; font-size:15px; border-radius:10px;">Sign In</button>
      <div class="text-center mt-3">
        <a href="#" data-bs-toggle="modal" data-bs-target="#forgotModal" style="color:var(--text-muted); font-size:12px; text-decoration:none; transition: color 0.2s;" onmouseover="this.style.color='var(--accent-primary)'" onmouseout="this.style.color='var(--text-muted)'">Forgot password / Reset Database?</a>
      </div>
    </form>
  </div>

  <!-- Forgot Password / Reset Database Modal -->
  <div class="modal fade" id="forgotModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content" style="background:#0f172a; border:1px solid var(--glass-border); color:#fff; border-radius:16px;">
        <div class="modal-header border-0 pb-0">
          <h5 class="modal-title font-mono" style="font-size:14px;"><i class="bi bi-info-circle text-warning me-2"></i>Forgot Password / Reset Instructions</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body" style="font-size:13px; line-height:1.6;">
          <p class="text-white">Since this is a self-hosted panel, for security reasons you must perform password or database resets directly on your server's terminal via SSH.</p>
          
          <h6 class="mt-3 text-warning font-mono" style="font-size:12px; font-weight:600;">Option 1: Reset Database to Default</h6>
          <p class="mb-2">Log in to your server and execute the reset script in the installation folder:</p>
          <pre class="p-3 rounded bg-dark text-success font-mono" style="font-size:11px; overflow-x:auto; margin-bottom:10px; border:1px solid rgba(255,255,255,0.05);">cd /opt/linux-panel && sudo npm run reset-db</pre>
          <p class="text-white mb-4" style="font-size:11.5px;">Note: This resets your SQLite database. The default login will revert to: <strong>admin / Admin@123456</strong>.</p>
          
          <h6 class="mt-3 text-warning font-mono" style="font-size:12px; font-weight:600;">Option 2: Re-enable Disabled Accounts</h6>
          <p class="mb-2">To force-activate all deactivated user accounts, run:</p>
          <pre class="p-3 rounded bg-dark text-success font-mono" style="font-size:11px; overflow-x:auto; border:1px solid rgba(255,255,255,0.05);">cd /opt/linux-panel && sudo node -e "import('better-sqlite3').then(m => { const db = new m.default('./storage/panelku.db'); db.prepare('UPDATE users SET is_active = 1').run(); console.log('Accounts active'); });"</pre>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
  <script>
    document.getElementById('loginForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const u = document.getElementById('username').value;
      const p = document.getElementById('password').value;
      const err = document.getElementById('errorMsg');
      
      try {
        const res = await LP.login(u, p);
        if(res && res.success) {
           if(res.requiresTwoFactor) {
              window.location.href = '/login/2fa?token=' + res.tempToken;
           } else {
              window.location.href = '/dashboard';
           }
        }
        else { err.textContent = (res && res.message) ? res.message : 'Login failed'; err.style.display = 'block'; }
      } catch (e) {
        console.error(e);
        err.textContent = 'Connection error';
        err.style.display = 'block';
      }
    });
  </script>
</body>
</html>
