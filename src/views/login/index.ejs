<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Linux Panel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/app.css" rel="stylesheet">
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
      background-image: url('/images/bg.png');
      background-size: cover;
      background-position: center;
    }
    .login-card {
      width: 100%;
      max-width: 400px;
      background: var(--glass-bg);
      backdrop-filter: blur(25px);
      -webkit-backdrop-filter: blur(25px);
      border: 1px solid var(--glass-border);
      border-radius: 20px;
      padding: 40px 30px;
      box-shadow: var(--glass-shadow);
      color: #fff;
    }
  </style>
</head>
<body>

  <div class="login-card">
    <div class="text-center mb-4">
      <div style="background: var(--accent-primary); width:48px; height:48px; border-radius:12px; display:inline-flex; align-items:center; justify-content:center; color:#fff; font-size:24px; margin-bottom:15px;">⚡</div>
      <h2 style="font-weight:700; font-size:1.5rem; margin-bottom:5px;">Welcome Back</h2>
      <p style="color:var(--text-muted); font-size:0.9rem;">Sign in to your Linux Panel</p>
    </div>

    <form id="loginForm">
      <div id="errorMsg" class="alert alert-danger" style="display:none; background:rgba(239, 68, 68, 0.2); color:#fca5a5; border:1px solid rgba(239, 68, 68, 0.3); font-size:13px; padding:10px;"></div>
      
      <div class="lp-form-group mb-3">
        <label class="lp-label">Username</label>
        <div class="input-group">
          <span class="input-group-text" style="background:rgba(0,0,0,0.3); border:1px solid var(--glass-border); color:var(--text-muted); border-right:none;"><i class="bi bi-person"></i></span>
          <input type="text" id="username" class="form-control" style="background:rgba(0,0,0,0.3); border:1px solid var(--glass-border); color:#fff; border-left:none;" required>
        </div>
      </div>
      
      <div class="lp-form-group mb-4">
        <label class="lp-label">Password</label>
        <div class="input-group">
          <span class="input-group-text" style="background:rgba(0,0,0,0.3); border:1px solid var(--glass-border); color:var(--text-muted); border-right:none;"><i class="bi bi-lock"></i></span>
          <input type="password" id="password" class="form-control" style="background:rgba(0,0,0,0.3); border:1px solid var(--glass-border); color:#fff; border-left:none;" required>
        </div>
      </div>

      <button type="submit" class="btn-lp btn-lp-primary w-100" style="padding:10px; font-size:15px; border-radius:10px;">Sign In</button>
    </form>
  </div>

  <script src="/js/app.js"></script>
  <script>
    document.getElementById('loginForm').addEventListener('submit', async function(e) {
      e.preventDefault();
      const u = document.getElementById('username').value;
      const p = document.getElementById('password').value;
      const err = document.getElementById('errorMsg');
      
      try {
        const res = await LP.login(u, p);
        if(res && res.success) {
           if(res.requiresTwoFactor) {
              window.location.href = '/login/2fa?token=' + res.tempToken;
           } else {
              window.location.href = '/dashboard';
           }
        }
        else { err.textContent = (res && res.message) ? res.message : 'Login failed'; err.style.display = 'block'; }
      } catch (e) {
        console.error(e);
        err.textContent = 'Connection error';
        err.style.display = 'block';
      }
    });
  </script>
</body>
</html>
