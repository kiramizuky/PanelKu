<style>
  .mdb-tab {
    padding: 10px 20px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .mdb-tab:hover { color: var(--text-primary); background: rgba(255,255,255,0.03); }
  .mdb-tab.active {
    color: var(--accent-primary);
    background: rgba(99,102,241,0.08);
    border-bottom-color: var(--accent-primary);
  }
  .mdb-tab-content { display: none; }
  .mdb-tab-content.active { display: block; animation: fadeIn 0.25s ease-out; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">
      <i class="bi bi-database-fill text-success me-2"></i> MongoDB Manager
    </h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">
      Manage MongoDB databases, collections, users, and run queries
    </p>
  </div>
  <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="MongoDBPage.refresh()"><i class="bi bi-arrow-clockwise me-1"></i> Refresh</button>
</div>

<!-- Status Cards -->
<div class="row g-3 mb-4">
  <div class="col-12 col-md-6 col-lg-3">
    <div class="lp-glass-card p-3 d-flex align-items-center gap-3" style="border-left:3px solid var(--accent-success);">
      <div style="width:44px;height:44px;border-radius:12px;background:rgba(16,185,129,0.12);display:flex;align-items:center;justify-content:center;font-size:22px;color:#10b981;flex-shrink:0;">
        <i class="bi bi-database-fill"></i>
      </div>
      <div>
        <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;">Status</div>
        <div id="mdbStatus" style="font-size:17px;font-weight:700;color:var(--text-primary);font-family:monospace;">—</div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-6 col-lg-3">
    <div class="lp-glass-card p-3 d-flex align-items-center gap-3" style="border-left:3px solid var(--accent-info);">
      <div style="width:44px;height:44px;border-radius:12px;background:rgba(59,130,246,0.12);display:flex;align-items:center;justify-content:center;font-size:22px;color:#3b82f6;flex-shrink:0;">
        <i class="bi bi-collection"></i>
      </div>
      <div>
        <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;">Version</div>
        <div id="mdbVersion" style="font-size:17px;font-weight:700;color:var(--text-primary);font-family:monospace;">—</div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-6 col-lg-3">
    <div class="lp-glass-card p-3 d-flex align-items-center gap-3" style="border-left:3px solid var(--accent-warning);">
      <div style="width:44px;height:44px;border-radius:12px;background:rgba(245,158,11,0.12);display:flex;align-items:center;justify-content:center;font-size:22px;color:#f59e0b;flex-shrink:0;">
        <i class="bi bi-hdd-stack"></i>
      </div>
      <div>
        <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;">Databases</div>
        <div id="mdbDbCount" style="font-size:17px;font-weight:700;color:var(--text-primary);font-family:monospace;">—</div>
      </div>
    </div>
  </div>
  <div class="col-12 col-md-6 col-lg-3">
    <div class="lp-glass-card p-3 d-flex align-items-center gap-3" style="border-left:3px solid var(--accent-danger);">
      <div style="width:44px;height:44px;border-radius:12px;background:rgba(239,68,68,0.12);display:flex;align-items:center;justify-content:center;font-size:22px;color:#ef4444;flex-shrink:0;">
        <i class="bi bi-people"></i>
      </div>
      <div>
        <div style="font-size:11px;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;">Users</div>
        <div id="mdbUserCount" style="font-size:17px;font-weight:700;color:var(--text-primary);font-family:monospace;">—</div>
      </div>
    </div>
  </div>
</div>

<!-- Not Installed Banner -->
<div id="mdbNotInstalledBanner" style="display:none;" class="mb-4">
  <div class="alert" style="background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2);border-radius:12px;padding:16px 20px;color:#f59e0b;">
    <div class="d-flex align-items-start gap-3">
      <i class="bi bi-exclamation-triangle-fill" style="font-size:20px;flex-shrink:0;margin-top:2px;"></i>
      <div>
        <strong>MongoDB is not installed or not running.</strong>
        <p style="margin:6px 0 0 0;font-size:13px;color:var(--text-muted);">
          Install MongoDB server and mongosh client to manage databases via this panel.
        </p>
        <button class="btn-lp btn-lp-primary btn-sm mt-2" onclick="MongoDBPage.installMongo()">
          <i class="bi bi-download me-1"></i> Install MongoDB
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Main Tabs -->
<div class="lp-glass-card mb-4" style="padding:0;overflow:hidden;">
  <div style="display:flex;border-bottom:1px solid var(--glass-border);overflow-x:auto;background:rgba(0,0,0,0.1);">
    <button class="mdb-tab active" data-tab="overview" onclick="MongoDBPage.switchTab('overview')"><i class="bi bi-speedometer2 me-1"></i> Overview</button>
    <button class="mdb-tab" data-tab="databases" onclick="MongoDBPage.switchTab('databases')"><i class="bi bi-database me-1"></i> Databases</button>
    <button class="mdb-tab" data-tab="users" onclick="MongoDBPage.switchTab('users')"><i class="bi bi-people me-1"></i> Users</button>
    <button class="mdb-tab" data-tab="query" onclick="MongoDBPage.switchTab('query')"><i class="bi bi-terminal me-1"></i> Query Console</button>
    <button class="mdb-tab" data-tab="backup" onclick="MongoDBPage.switchTab('backup')"><i class="bi bi-cloud-arrow-up me-1"></i> Backup</button>
  </div>

  <!-- Tab: Overview -->
  <div id="tab-overview" class="mdb-tab-content active" style="padding:20px;">
    <div class="row g-4">
      <div class="col-12 col-lg-6">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);min-height:200px;">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;margin-bottom:16px;"><i class="bi bi-server me-1"></i> Server Info</h6>
          <table class="lp-table" style="font-size:13px;">
            <tbody id="mdbServerInfoTable">
              <tr><td style="padding:5px 0;color:var(--text-muted);width:120px;">Uptime</td><td id="mdbUptime" style="padding:5px 0;">—</td></tr>
              <tr><td style="padding:5px 0;color:var(--text-muted);">Connections</td><td id="mdbConnections" style="padding:5px 0;">—</td></tr>
              <tr><td style="padding:5px 0;color:var(--text-muted);">Storage Engine</td><td id="mdbStorageEngine" style="padding:5px 0;">—</td></tr>
              <tr><td style="padding:5px 0;color:var(--text-muted);">Memory</td><td id="mdbMemory" style="padding:5px 0;">—</td></tr>
              <tr><td style="padding:5px 0;color:var(--text-muted);">Operations</td><td id="mdbOps" style="padding:5px 0;">—</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="col-12 col-lg-6">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);min-height:200px;">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;margin-bottom:16px;"><i class="bi bi-hdd-stack me-1"></i> Database Sizes</h6>
          <div id="mdbDatabaseSizes" style="display:flex;flex-direction:column;gap:8px;">
            <div style="padding:20px;text-align:center;color:var(--text-muted);font-size:13px;">Loading...</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Tab: Databases -->
  <div id="tab-databases" class="mdb-tab-content" style="padding:20px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 style="font-size:15px;font-weight:600;color:var(--text-primary);margin:0;"><i class="bi bi-database text-primary me-1"></i> Databases</h5>
      <button class="btn-lp btn-lp-primary btn-sm" onclick="MongoDBPage.showCreateDb()"><i class="bi bi-plus-lg me-1"></i> Create Database</button>
    </div>
    <div id="mdbDatabaseList" style="display:flex;flex-direction:column;gap:8px;">
      <div style="padding:20px;text-align:center;color:var(--text-muted);"><div class="spinner-border spinner-border-sm text-primary me-2"></div> Loading...</div>
    </div>

    <!-- Collections inside a database -->
    <div id="mdbCollectionsPanel" style="display:none;margin-top:20px;">
      <hr style="border-color:var(--glass-border);">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 style="font-size:15px;font-weight:600;color:var(--text-primary);margin:0;">
          <i class="bi bi-collection text-info me-1"></i> Collections: <span id="mdbCurrentDbName" style="font-family:monospace;"></span>
        </h5>
        <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="MongoDBPage.backToDatabases()"><i class="bi bi-arrow-left me-1"></i> Back</button>
      </div>
      <div id="mdbCollectionList" style="display:flex;flex-direction:column;gap:6px;">
        <div style="padding:15px;text-align:center;color:var(--text-muted);font-size:13px;">Select a database to view collections.</div>
      </div>
    </div>
  </div>

  <!-- Tab: Users -->
  <div id="tab-users" class="mdb-tab-content" style="padding:20px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 style="font-size:15px;font-weight:600;color:var(--text-primary);margin:0;"><i class="bi bi-people text-primary me-1"></i> MongoDB Users</h5>
      <button class="btn-lp btn-lp-primary btn-sm" onclick="MongoDBPage.showCreateUser()"><i class="bi bi-plus-lg me-1"></i> Create User</button>
    </div>
    <div class="table-responsive">
      <table class="lp-table">
        <thead><tr><th>Username</th><th>Database</th><th>Roles</th><th>Auth Mechanisms</th><th style="text-align:right">Actions</th></tr></thead>
        <tbody id="mdbUsersTableBody"><tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr></tbody>
      </table>
    </div>
  </div>

  <!-- Tab: Query Console -->
  <div id="tab-query" class="mdb-tab-content" style="padding:20px;">
    <div class="mb-3">
      <h5 style="font-size:15px;font-weight:600;color:var(--text-primary);margin:0 0 15px 0;"><i class="bi bi-terminal text-primary me-1"></i> MongoDB Query Console</h5>
      <div class="lp-form-group mb-3">
        <label class="lp-label">Database</label>
        <select id="mdbQueryDb" class="lp-input"><option value="">Select a database...</option></select>
      </div>
      <div class="lp-form-group mb-3">
        <label class="lp-label">JavaScript Query</label>
        <textarea id="mdbQueryInput" class="lp-input font-mono" rows="4" placeholder='db.users.find({}).limit(10).toArray()' style="font-size:12px;resize:vertical;"></textarea>
        <small style="font-size:11px;color:var(--text-muted);">Run any MongoDB JavaScript expression on the selected database.</small>
      </div>
      <button class="btn-lp btn-lp-primary" onclick="MongoDBPage.runQuery()"><i class="bi bi-play-fill me-1"></i> Run Query</button>
      <button class="btn-lp btn-lp-ghost btn-lp-sm ms-2" onclick="document.getElementById('mdbQueryResult').textContent='';document.getElementById('mdbQueryInput').value=''">Clear</button>
    </div>
    <div id="mdbQueryResult" style="display:none;margin-top:15px;">
      <h6 style="font-size:12px;font-weight:600;color:var(--text-muted);margin-bottom:8px;">Result</h6>
      <pre style="background:#0a0a0f;color:#00ff88;padding:15px;border-radius:8px;font-size:12px;font-family:monospace;max-height:400px;overflow-y:auto;white-space:pre-wrap;word-break:break-all;"></pre>
    </div>
  </div>

  <!-- Tab: Backup -->
  <div id="tab-backup" class="mdb-tab-content" style="padding:20px;">
    <div class="row g-4">
      <div class="col-12 col-md-6">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:15px;"><i class="bi bi-cloud-arrow-up me-1"></i> Backup Database</h6>
          <div class="lp-form-group mb-3">
            <label class="lp-label">Database (leave empty for all)</label>
            <select id="mdbBackupDb" class="lp-input"><option value="">All databases</option></select>
          </div>
          <button class="btn-lp btn-lp-primary" onclick="MongoDBPage.runBackup()"><i class="bi bi-cloud-arrow-up me-1"></i> Run mongodump</button>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:15px;"><i class="bi bi-cloud-arrow-down me-1"></i> Restore Backup</h6>
          <div class="lp-form-group mb-3">
            <label class="lp-label">Backup Directory Path</label>
            <input type="text" id="mdbRestorePath" class="lp-input font-mono" placeholder="/opt/panelku/storage/backups/mongodb_...">
          </div>
          <div class="lp-form-group mb-3">
            <label class="lp-label">Database Name (optional, leave empty for all)</label>
            <input type="text" id="mdbRestoreDb" class="lp-input" placeholder="my_database">
          </div>
          <button class="btn-lp btn-lp-primary" onclick="MongoDBPage.runRestore()"><i class="bi bi-cloud-arrow-down me-1"></i> Run mongorestore</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Create Database Modal -->
<div class="modal fade" id="createMongoDbModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border:1px solid rgba(255,255,255,0.1);background:rgba(20,20,25,0.95);">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);">
        <h5 class="modal-title font-mono text-white" style="font-size:15px;"><i class="bi bi-database-plus text-primary me-2"></i> Create Database</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="lp-form-group">
          <label class="lp-label">Database Name</label>
          <input type="text" id="mdbNewDbName" class="lp-input font-mono" placeholder="e.g. my_app" required>
        </div>
      </div>
      <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);">
        <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-lp btn-lp-primary" onclick="MongoDBPage.createDatabase()"><i class="bi bi-plus-circle me-1"></i> Create</button>
      </div>
    </div>
  </div>
</div>

<!-- Create User Modal -->
<div class="modal fade" id="createMongoUserModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border:1px solid rgba(255,255,255,0.1);background:rgba(20,20,25,0.95);">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);">
        <h5 class="modal-title font-mono text-white" style="font-size:15px;"><i class="bi bi-person-plus text-primary me-2"></i> Create MongoDB User</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="lp-form-group mb-3">
          <label class="lp-label">Username</label>
          <input type="text" id="mdbNewUsername" class="lp-input" required>
        </div>
        <div class="lp-form-group mb-3">
          <label class="lp-label">Password</label>
          <input type="password" id="mdbNewPassword" class="lp-input" required>
        </div>
        <div class="lp-form-group">
          <label class="lp-label">Roles (comma separated: role@db)</label>
          <input type="text" id="mdbNewUserRoles" class="lp-input" placeholder="readWrite@myapp, read@anotherdb" value="readWrite@admin">
          <small style="font-size:11px;color:var(--text-muted);">Format: role@database, e.g. readWrite@myapp, dbAdmin@admin</small>
        </div>
      </div>
      <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);">
        <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-lp btn-lp-primary" onclick="MongoDBPage.createUser()"><i class="bi bi-person-plus me-1"></i> Create</button>
      </div>
    </div>
  </div>
</div>

<script src="/js/mongodb.js"></script>
