<!-- Page Header -->
<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">File Manager</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Manage host files securely</p>
  </div>
  <div style="display:flex;gap:10px">
    <button class="btn-lp btn-lp-ghost" id="toggleViewBtn" onclick="FMPage.toggleView()" title="Toggle View"><i class="bi bi-grid"></i></button>
    <button class="btn-lp btn-lp-primary" onclick="FMPage.createFolder()"><i class="bi bi-folder-plus"></i> New Folder</button>
    <button class="btn-lp btn-lp-primary" onclick="FMPage.showUploadModal()"><i class="bi bi-upload"></i> Upload</button>
  </div>
</div>

<!-- Toolbar -->
<div class="lp-glass-card" style="padding:0;">
  <div class="lp-card-header" style="background:rgba(0,0,0,0.2); border-bottom:1px solid var(--glass-border); padding:10px 20px; display:flex; align-items:center; gap:10px;">
    <button class="btn-lp btn-lp-ghost btn-lp-sm" id="upBtn" onclick="FMPage.goUp()" title="Go Up" disabled><i class="bi bi-arrow-up"></i></button>
    <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="FMPage.refresh()" title="Refresh"><i class="bi bi-arrow-clockwise"></i></button>
    <input type="text" id="currentPath" class="lp-input font-mono" style="flex:1; padding:6px 10px; margin:0;" onkeypress="if(event.key==='Enter') FMPage.navigate(this.value)" placeholder="/">
  </div>

  <!-- Bulk Actions Bar -->
  <div id="fmBulkBar" style="display:none; background: rgba(59,130,246,0.1); border-bottom:1px solid rgba(59,130,246,0.2); padding:8px 20px; align-items:center; gap:12px;">
    <span class="text-white font-mono" style="font-size:12px; font-weight:600;"><i class="bi bi-check2-all me-1"></i> <span id="bulkSelectedCount">0</span> selected</span>
    <div style="flex:1; display:flex; gap:8px; justify-content:flex-end;">
      <button class="btn-lp btn-lp-ghost btn-lp-sm text-white" onclick="FMPage.bulkCompress()"><i class="bi bi-file-zip-fill me-1"></i> Compress</button>
      <button class="btn-lp btn-lp-ghost btn-lp-sm text-white" onclick="FMPage.bulkDownload()"><i class="bi bi-download me-1"></i> Download</button>
      <button class="btn-lp btn-lp-ghost btn-lp-sm text-white" onclick="FMPage.bulkChmod()"><i class="bi bi-key-fill me-1"></i> Permission</button>
      <button class="btn-lp btn-lp-ghost btn-lp-sm text-danger" onclick="FMPage.bulkDelete()"><i class="bi bi-trash3-fill me-1"></i> Delete</button>
    </div>
  </div>

  <!-- File Grid/List container -->
  <div id="fmWrapper" class="lp-card-body" style="padding:10px; min-height:300px;">
    <div id="fmGrid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap:10px;">
      <div style="grid-column:1/-1; padding:40px; text-align:center; color:var(--text-muted)">Loading...</div>
    </div>
  </div>
</div>

<!-- Context Menu -->
<div id="fmContextMenu" style="display:none; position:fixed; background:var(--bg-secondary); border:1px solid var(--glass-border); border-radius:8px; min-width:160px; z-index:9000; box-shadow:0 8px 24px rgba(0,0,0,0.4); padding:4px 0;">
  <div class="fm-ctx-item" onclick="FMPage.openSelected()"><i class="bi bi-folder2-open"></i> Open</div>
  <div class="fm-ctx-item" onclick="FMPage.renameSelected()"><i class="bi bi-pencil"></i> Rename</div>
  <div class="fm-ctx-item" onclick="FMPage.copySelected()"><i class="bi bi-clipboard"></i> Copy</div>
  <div class="fm-ctx-item" onclick="FMPage.pasteItem()"><i class="bi bi-clipboard-check"></i> Paste</div>
  <div class="fm-ctx-item" onclick="FMPage.downloadSelected()"><i class="bi bi-download"></i> Download</div>
  <hr style="margin:4px 0; border-color:var(--glass-border)">
  <div class="fm-ctx-item text-danger" onclick="FMPage.deleteSelected()"><i class="bi bi-trash"></i> Delete</div>
</div>

<!-- Drop Overlay -->
<div id="dropOverlay" style="display:none; position:fixed; inset:0; background:rgba(99,102,241,0.2); border:3px dashed var(--accent-primary); z-index:9000; align-items:center; justify-content:center; pointer-events:none;">
  <div style="text-align:center; color:var(--accent-primary);">
    <i class="bi bi-cloud-upload" style="font-size:64px;"></i>
    <h3 style="margin-top:10px; color:#fff;">Drop files to upload</h3>
  </div>
</div>

<!-- Text Editor Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content" style="background:var(--bg-primary); border:1px solid var(--glass-border);">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:13px;" id="editModalTitle">Edit File</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="padding:0;">
        <textarea id="fileEditContent" style="width:100%; height:500px; background:#0d1117; color:#e6edf3; font-family:'JetBrains Mono',monospace; font-size:13px; border:none; padding:16px; resize:none; outline:none;"></textarea>
      </div>
      <div class="modal-footer">
        <button class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button class="btn-lp btn-lp-primary" onclick="FMPage.saveEdit()"><i class="bi bi-floppy"></i> Save</button>
      </div>
    </div>
  </div>
</div>

<!-- File Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border: 1px solid rgba(255,255,255,0.1); background: rgba(20,20,25,0.98); border-radius:12px;">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1); padding:15px 20px;">
        <h5 class="modal-title font-mono text-white" style="font-size:15px;"><i class="bi bi-cloud-upload text-primary me-2"></i>Upload Files</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="padding: 20px;">
        
        <!-- Drag & Drop Zone inside Modal -->
        <div id="modalDragZone" style="border: 2px dashed rgba(255,255,255,0.15); border-radius: 10px; padding: 30px 20px; text-align: center; background: rgba(0,0,0,0.15); cursor: pointer; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--accent-primary)'; this.style.background='rgba(59,130,246,0.05)';" onmouseout="this.style.borderColor='rgba(255,255,255,0.15)'; this.style.background='rgba(0,0,0,0.15)';" onclick="document.getElementById('modalFileInput').click()">
          <i class="bi bi-cloud-arrow-up-fill text-muted" style="font-size: 40px; display: block; margin-bottom: 12px; transition: color 0.2s;"></i>
          <span class="text-white" style="font-size: 13.5px; font-weight: 600; display: block;">Drag & Drop files here</span>
          <span style="font-size: 11.5px; color: var(--text-muted); display: block; margin-top: 4px;">or click to browse local files</span>
          <input type="file" id="modalFileInput" style="display:none;" multiple onchange="FMPage.handleSelectedUploads(this.files)">
        </div>

        <!-- Files list preview -->
        <div id="modalUploadFilesList" class="mt-3" style="max-height: 160px; overflow-y: auto; display: flex; flex-direction: column; gap: 8px;">
          <!-- Items inserted via JS -->
        </div>

      </div>
      <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1); padding:15px 20px;">
        <button type="button" class="btn-lp btn-lp-ghost btn-lp-sm" data-bs-dismiss="modal">Close</button>
        <button type="button" id="btnStartUpload" class="btn-lp btn-lp-primary btn-lp-sm" onclick="FMPage.startSelectedUploads()" disabled><i class="bi bi-upload me-1"></i> Start Upload</button>
      </div>
    </div>
  </div>
</div>

<style>
  #dropOverlay { display:none; }
  #dropOverlay.visible { display:flex !important; }
  .fm-item {
    padding:12px 8px; border-radius:8px; cursor:pointer; text-align:center;
    transition:background 0.15s; border:1px solid transparent; user-select:none;
    position: relative;
  }
  .fm-item:hover { background:var(--glass-bg); }
  .fm-item.selected { background:rgba(99,102,241,0.2); border-color:var(--accent-primary); }
  
  /* Checkbox styling */
  .fm-checkbox-wrapper {
    position: absolute;
    top: 6px;
    left: 6px;
    z-index: 10;
  }
  .fm-checkbox {
    width: 15px;
    height: 15px;
    cursor: pointer;
    border-radius: 4px;
    border: 1px solid var(--glass-border);
    accent-color: var(--accent-primary);
  }

  .fm-item-permissions, .fm-item-owner { display:none; }
  .fm-item-icon { font-size:32px; margin-bottom:4px; }
  .fm-item-name { font-size:13px; font-weight:500; color:var(--text-primary); word-break:break-all; line-height:1.3; }
  .fm-item-size { font-size:11px; color:var(--text-muted); margin-top:2px; }
  
  .fm-list-view #fmGrid { grid-template-columns:1fr !important; }
  .fm-list-view .fm-item { display:flex; align-items:center; gap:12px; text-align:left; padding:8px 12px; }
  .fm-list-view .fm-checkbox-wrapper {
    position: static;
    margin-right: 4px;
  }
  .fm-list-view .fm-item-icon { font-size:18px; margin:0; }
  .fm-list-view .fm-item-name { font-size:14px; flex:1; }
  .fm-list-view .fm-item-permissions { display: block; font-size:12px; color:var(--text-muted); width: 80px; text-align: left; }
  .fm-list-view .fm-item-owner { display: block; font-size:12px; color:var(--text-muted); width: 120px; text-align: left; }
  .fm-list-view .fm-item-size { font-size:12px; margin:0; width: 90px; text-align: right; }
  
  .fm-ctx-item { padding:8px 16px; cursor:pointer; font-size:13px; display:flex; align-items:center; gap:8px; color:var(--text-primary); }
  .fm-ctx-item:hover { background:var(--glass-bg); }
  .fm-ctx-item i { width:16px; }
</style>

<script src="/js/filemanager.js"></script>
