<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">File Manager</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Manage host files securely</p>
  </div>
  <div style="display:flex;gap:10px">
    <button class="btn-lp btn-lp-primary" onclick="FMPage.createFolder()"><i class="bi bi-folder-plus"></i> New Folder</button>
    <button class="btn-lp btn-lp-primary" onclick="document.getElementById('fileUpload').click()"><i class="bi bi-upload"></i> Upload</button>
    <input type="file" id="fileUpload" style="display:none" onchange="FMPage.uploadFile(event)">
  </div>
</div>

<div class="lp-glass-card" style="padding:0;">
  <div class="lp-card-header" style="background:rgba(0,0,0,0.2); border-bottom:1px solid var(--glass-border); padding:10px 20px; display:flex; align-items:center; gap:10px;">
    <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="FMPage.goUp()" title="Up"><i class="bi bi-arrow-up"></i></button>
    <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="FMPage.loadPath(FMPage.currentPath)" title="Refresh"><i class="bi bi-arrow-clockwise"></i></button>
    <input type="text" id="pathInput" class="lp-input font-mono" style="flex:1; padding:6px 10px; margin:0;" onkeypress="if(event.key==='Enter') FMPage.loadPath(this.value)">
  </div>

  <div class="lp-card-body" style="padding:0;overflow-x:auto;">
    <table class="lp-table">
      <thead>
        <tr>
          <th style="width:50%">Name</th>
          <th style="width:15%">Size</th>
          <th style="width:20%">Modified</th>
          <th style="text-align:right">Actions</th>
        </tr>
      </thead>
      <tbody id="fileList">
        <tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script src="/js/filemanager.js"></script>
