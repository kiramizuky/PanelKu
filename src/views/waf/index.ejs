<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">Web Application Firewall (WAF)</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Manage IP blacklists and security rules</p>
  </div>
  <button class="btn-lp btn-lp-primary" onclick="WAFPage.showAddModal()"><i class="bi bi-shield-plus"></i> Add Rule</button>
</div>

<div class="row g-4">
  <!-- Left Side: WAF Rules -->
  <div class="col-12 col-xl-7">
    <div class="lp-glass-card" style="padding:0;overflow-x:auto;">
      <table class="lp-table">
        <thead>
          <tr>
            <th>Type</th>
            <th>Value</th>
            <th>Action</th>
            <th>Description</th>
            <th style="text-align:right">Options</th>
          </tr>
        </thead>
        <tbody id="wafTableBody">
          <tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
        </tbody>
      </table>
      <div id="wafPagination" style="padding: 0 15px 15px 15px;"></div>
    </div>
  </div>

  <!-- Right Side: Fail2Ban Logs -->
  <div class="col-12 col-xl-5">
    <div class="lp-glass-card" style="padding:25px; display:flex; flex-direction:column; height:100%; min-height:400px;">
      <div style="border-bottom:1px solid var(--glass-border); padding-bottom:12px; margin-bottom:15px; display:flex; justify-content:space-between; align-items:center;">
        <h5 style="font-weight:700; margin:0; color:var(--text-primary); font-size:14px;"><i class="bi bi-activity me-2 text-danger"></i>Fail2Ban Intrusion Logs</h5>
        <div style="display:flex; gap:6px;">
          <button class="btn-lp btn-lp-ghost btn-lp-sm text-primary" onclick="WAFPage.askAILog()" style="font-size:11px; padding:4px 8px;" title="Analyze logs with AI"><i class="bi bi-robot"></i> Ask AI</button>
          <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="WAFPage.loadFail2BanLogs()" style="font-size:11px; padding:4px 8px;"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
        </div>
      </div>
      <div style="flex:1; background:rgba(0,0,0,0.25); border:1px solid var(--glass-border); border-radius:10px; padding:15px; font-family:monospace; font-size:11.5px; overflow-y:auto; max-height: 400px; color: var(--text-secondary);">
        <pre id="fail2banLogs" style="margin:0; white-space:pre-wrap; word-break:break-all; line-height:1.5;">Loading logs...</pre>
      </div>
    </div>
  </div>
</div>

<!-- Add Rule Modal -->
<div class="modal fade" id="addRuleModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px">Add WAF Rule</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="addRuleForm" onsubmit="WAFPage.addRule(event)">
        <div class="modal-body">
          <div class="lp-form-group">
            <label class="lp-label">Type</label>
            <select id="ruleType" class="lp-input" required>
              <option value="ip">IP Address</option>
              <option value="country">Country (ISO Code)</option>
              <option value="user_agent">User Agent (Regex)</option>
            </select>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Value</label>
            <input type="text" id="ruleValue" class="lp-input" placeholder="e.g. 192.168.1.100" required>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Action</label>
            <select id="ruleAction" class="lp-input" required>
              <option value="block">Block</option>
              <option value="allow">Allow (Whitelist)</option>
            </select>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Description (Optional)</label>
            <input type="text" id="ruleDescription" class="lp-input" placeholder="e.g. Blocked bad bot">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary">Add Rule</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/waf.js"></script>
