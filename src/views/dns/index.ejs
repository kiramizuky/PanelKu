<style>
  .dns-tab {
    padding: 10px 20px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .dns-tab:hover { color: var(--text-primary); background: rgba(255,255,255,0.03); }
  .dns-tab.active {
    color: var(--accent-primary);
    background: rgba(99,102,241,0.08);
    border-bottom-color: var(--accent-primary);
  }
  .dns-tab-content { display: none; }
  .dns-tab-content.active { display: block; animation: fadeIn 0.25s ease-out; }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .provider-card {
    cursor: pointer; transition: all 0.2s ease;
    border: 1px solid transparent;
  }
  .provider-card:hover { border-color: var(--accent-primary); transform: translateY(-2px); }
  .provider-card.active { border-color: var(--accent-primary); background: rgba(99,102,241,0.08); }
</style>

<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">
      <i class="bi bi-globe2 text-info me-2"></i> DNS Manager
    </h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">
      Multi-Provider DNS Management — Cloudflare, DigitalOcean, DuckDNS, No-IP
    </p>
  </div>
</div>

<!-- Providers Row -->
<div class="row g-2 mb-4" id="providersRow">
  <div class="col-12"><div style="font-size:12px;color:var(--text-muted);margin-bottom:8px;">Select Provider:</div></div>
</div>

<!-- Main Content -->
<div id="dnsWorkspace" style="display:none;">
  <!-- Provider Header -->
  <div id="providerHeader" class="lp-glass-card mb-3" style="padding:14px 18px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;">
    <div>
      <h3 id="currentProviderName" style="font-size:16px;font-weight:600;margin:0;display:flex;align-items:center;gap:8px;"></h3>
      <span id="currentProviderStatus" style="font-size:12px;color:var(--text-muted);"></span>
    </div>
    <div style="display:flex;gap:8px;">
      <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="DNSPage.testConnection()"><i class="bi bi-plug me-1"></i> Test</button>
      <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="DNSPage.showConfig()"><i class="bi bi-gear me-1"></i> Config</button>
    </div>
  </div>

  <!-- Tabs -->
  <div class="lp-glass-card" style="padding:0;overflow:hidden;">
    <div style="display:flex;border-bottom:1px solid var(--glass-border);overflow-x:auto;background:rgba(0,0,0,0.1);">
      <button class="dns-tab active" data-tab="zones" onclick="DNSPage.switchTab('zones')">
        <i class="bi bi-globe me-1"></i> Zones &amp; Records
      </button>
      <button class="dns-tab" data-tab="dnssec" onclick="DNSPage.switchTab('dnssec')">
        <i class="bi bi-shield-check me-1"></i> DNSSEC
      </button>
      <button class="dns-tab" data-tab="dynamic" onclick="DNSPage.switchTab('dynamic')">
        <i class="bi bi-arrow-repeat me-1"></i> Dynamic DNS
      </button>
    </div>

    <!-- Tab: Zones & Records -->
    <div id="tab-zones" class="dns-tab-content active" style="padding:20px;">
      <div class="row g-3">
        <div class="col-12 col-md-4">
          <h5 style="font-size:13px;font-weight:600;color:var(--text-muted);text-transform:uppercase;margin-bottom:10px;">
            <i class="bi bi-globe me-1"></i> Zones
          </h5>
          <div id="zonesList" style="display:flex;flex-direction:column;gap:6px;max-height:400px;overflow-y:auto;">
            <div style="color:var(--text-muted);font-size:13px;padding:10px;">Select a provider to load zones...</div>
          </div>
        </div>
        <div class="col-12 col-md-8">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-wrap:wrap;gap:6px;">
            <h5 id="currentZoneName" style="font-size:15px;font-weight:600;margin:0;color:var(--text-primary);">No Zone Selected</h5>
            <div style="display:flex;gap:6px;">
              <input type="text" id="recordFilter" class="lp-input" style="width:150px;display:inline-block;font-size:12px;" placeholder="Filter records..." oninput="DNSPage.filterRecords()">
              <button class="btn-lp btn-lp-primary btn-sm" onclick="DNSPage.showAddRecordModal()" id="addRecordBtn" style="display:none;">
                <i class="bi bi-plus-lg me-1"></i> Add Record
              </button>
            </div>
          </div>
          <div class="table-responsive">
            <table class="lp-table">
              <thead>
                <tr>
                  <th>Type</th>
                  <th>Name</th>
                  <th>Content</th>
                  <th>TTL</th>
                  <th style="text-align:right">Actions</th>
                </tr>
              </thead>
              <tbody id="recordsTableBody">
                <tr><td colspan="5" style="text-align:center;padding:20px;color:var(--text-muted)">Select a zone to view records</td></tr>
              </tbody>
            </table>
          </div>
          <div id="dnsPagination" style="padding:5px 0;"></div>
        </div>
      </div>
    </div>

    <!-- Tab: DNSSEC -->
    <div id="tab-dnssec" class="dns-tab-content" style="padding:20px;">
      <div id="dnssecContent">
        <div style="text-align:center;padding:30px;color:var(--text-muted);">
          <i class="bi bi-shield-check" style="font-size:32px;display:block;margin-bottom:10px;"></i>
          Select a zone to view DNSSEC status
        </div>
      </div>
    </div>

    <!-- Tab: Dynamic DNS -->
    <div id="tab-dynamic" class="dns-tab-content" style="padding:20px;">
      <div class="row g-3">
        <div class="col-12 col-md-6">
          <div class="lp-glass-card" style="background:rgba(0,0,0,0.08);">
            <h5 style="font-size:14px;font-weight:600;margin-bottom:14px;">
              <i class="bi bi-duck text-warning me-1"></i> DuckDNS
            </h5>
            <p style="font-size:12px;color:var(--text-muted);margin-bottom:12px;">Update your DuckDNS domain's IP address</p>
            <div class="lp-form-group mb-2">
              <label class="lp-label">Domain</label>
              <input type="text" id="ddDomain" class="lp-input font-mono" placeholder="my-domain" style="font-size:13px;">
            </div>
            <div class="lp-form-group mb-2">
              <label class="lp-label">IPv4 (optional)</label>
              <input type="text" id="ddIp" class="lp-input font-mono" placeholder="auto-detect" style="font-size:13px;">
            </div>
            <div class="lp-form-group mb-2">
              <label class="lp-label">IPv6 (optional)</label>
              <input type="text" id="ddIpv6" class="lp-input font-mono" placeholder="" style="font-size:13px;">
            </div>
            <button class="btn-lp btn-lp-primary w-100" onclick="DNSPage.updateDuckDNS()">
              <i class="bi bi-arrow-repeat me-1"></i> Update DuckDNS
            </button>
          </div>
        </div>
        <div class="col-12 col-md-6">
          <div class="lp-glass-card" style="background:rgba(0,0,0,0.08);">
            <h5 style="font-size:14px;font-weight:600;margin-bottom:14px;">
              <i class="bi bi-globe text-info me-1"></i> No-IP
            </h5>
            <p style="font-size:12px;color:var(--text-muted);margin-bottom:12px;">Update your No-IP hostname's IP address</p>
            <div class="lp-form-group mb-2">
              <label class="lp-label">Hostname</label>
              <input type="text" id="niHostname" class="lp-input font-mono" placeholder="myhost.no-ip.org" style="font-size:13px;">
            </div>
            <div class="lp-form-group mb-2">
              <label class="lp-label">IP Address (optional)</label>
              <input type="text" id="niIp" class="lp-input font-mono" placeholder="auto-detect" style="font-size:13px;">
            </div>
            <button class="btn-lp btn-lp-primary w-100" onclick="DNSPage.updateNoIP()">
              <i class="bi bi-arrow-repeat me-1"></i> Update No-IP
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Provider Config Modal -->
<div class="modal fade" id="providerConfigModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border:1px solid rgba(255,255,255,0.1);background:rgba(20,20,25,0.95);">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);">
        <h5 class="modal-title" style="font-size:15px;"><i class="bi bi-gear text-primary me-1"></i> <span id="pcTitle">Provider Config</span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div id="pcFields"></div>
      </div>
      <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);">
        <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-lp btn-lp-primary" onclick="DNSPage.saveProviderConfig()">Save</button>
      </div>
    </div>
  </div>
</div>

<!-- Add/Edit Record Modal -->
<div class="modal fade" id="recordModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border:1px solid rgba(255,255,255,0.1);background:rgba(20,20,25,0.95);">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);">
        <h5 class="modal-title" style="font-size:15px;"><i class="bi bi-plus-circle text-primary me-1"></i> <span id="recModalTitle">Add Record</span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="recEditId">
        <div class="row g-2">
          <div class="col-4">
            <div class="lp-form-group">
              <label class="lp-label">Type</label>
              <select id="recType" class="lp-input" onchange="DNSPage.toggleRecordFields()">
                <option value="A">A</option>
                <option value="AAAA">AAAA</option>
                <option value="CNAME">CNAME</option>
                <option value="TXT">TXT</option>
                <option value="MX">MX</option>
                <option value="NS">NS</option>
                <option value="SRV">SRV</option>
                <option value="CAA">CAA</option>
              </select>
            </div>
          </div>
          <div class="col-8">
            <div class="lp-form-group">
              <label class="lp-label">Name</label>
              <input type="text" id="recName" class="lp-input font-mono" placeholder="@ or subdomain" style="font-size:13px;">
            </div>
          </div>
        </div>
        <div class="lp-form-group">
          <label class="lp-label">Content / Value</label>
          <input type="text" id="recContent" class="lp-input font-mono" placeholder="192.168.1.1" style="font-size:13px;">
        </div>
        <div class="row g-2">
          <div class="col-6">
            <div class="lp-form-group">
              <label class="lp-label">TTL (seconds)</label>
              <input type="number" id="recTtl" class="lp-input" value="1" min="1" max="86400" style="font-size:13px;">
            </div>
          </div>
          <div class="col-6" id="recPriorityGroup" style="display:none;">
            <div class="lp-form-group">
              <label class="lp-label">Priority</label>
              <input type="number" id="recPriority" class="lp-input" value="10" min="0" max="65535" style="font-size:13px;">
            </div>
          </div>
        </div>
        <div class="row g-2" id="recSrvGroup" style="display:none;">
          <div class="col-6">
            <div class="lp-form-group">
              <label class="lp-label">Weight</label>
              <input type="number" id="recWeight" class="lp-input" value="5" min="0" max="65535" style="font-size:13px;">
            </div>
          </div>
          <div class="col-6">
            <div class="lp-form-group">
              <label class="lp-label">Port</label>
              <input type="number" id="recPort" class="lp-input" value="443" min="0" max="65535" style="font-size:13px;">
            </div>
          </div>
        </div>
        <div class="form-check form-switch mt-3" id="recProxyGroup">
          <input class="form-check-input" type="checkbox" id="recProxied" checked>
          <label class="form-check-label" for="recProxied" style="font-size:13px;">Proxied (Cloudflare CDN)</label>
        </div>
      </div>
      <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);">
        <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-lp btn-lp-primary" onclick="DNSPage.saveRecord()">
          <i class="bi bi-check-lg me-1"></i> Save Record
        </button>
      </div>
    </div>
  </div>
</div>

<script src="/js/dns.js"></script>
