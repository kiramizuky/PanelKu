<div class="row g-4 align-items-start">
  <!-- Left Side: Navigation -->
  <div class="col-12 col-lg-4">
    <div class="settings-sidebar">
      <div class="settings-sidebar-header">
        <div style="position:relative; display:inline-block;">
          <div class="settings-avatar" style="margin:0 auto 10px;">
            <i class="bi bi-shield-lock-fill"></i>
          </div>
        </div>
        <h5 class="settings-sidebar-name">Authentication</h5>
        <p class="settings-sidebar-sub">SSO &amp; LDAP Configuration</p>
      </div>

      <!-- Navigation List -->
      <div class="settings-nav">
        <a href="/settings/profile" class="settings-nav-item">
          <i class="bi bi-person-fill"></i> My Profile
        </a>
        <a href="/settings/users" class="settings-nav-item">
          <i class="bi bi-people"></i> Users
        </a>
        <a href="/settings/roles" class="settings-nav-item">
          <i class="bi bi-shield-lock"></i> Roles &amp; Permissions
        </a>
        <a href="/settings/auth" class="settings-nav-item active">
          <i class="bi bi-key-fill"></i> SSO / LDAP
        </a>
        <a href="/settings/themes" class="settings-nav-item">
          <i class="bi bi-palette"></i> Themes
        </a>
        <a href="/settings/audit" class="settings-nav-item">
          <i class="bi bi-journal-text"></i> Audit Log
        </a>
        <a href="/settings/changelog" class="settings-nav-item">
          <i class="bi bi-file-earmark-text"></i> Changelog
        </a>
      </div>
    </div>
  </div>

  <!-- Right Side: SSO & LDAP Configuration -->
  <div class="col-12 col-lg-8">
    <!-- Tabs Navigation -->
    <ul class="nav nav-tabs lp-tabs mb-4" id="authTabs" role="tablist" style="border-bottom: 1px solid var(--glass-border);">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="sso-tab" data-bs-toggle="tab" data-bs-target="#sso-panel" type="button" role="tab">
          <i class="bi bi-google me-1"></i> SSO Providers
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="ldap-tab" data-bs-toggle="tab" data-bs-target="#ldap-panel" type="button" role="tab">
          <i class="bi bi-building me-1"></i> LDAP / Enterprise
        </button>
      </li>
    </ul>

    <div class="tab-content" id="authTabContent">
      <!-- ── SSO Panel ── -->
      <div class="tab-pane fade show active" id="sso-panel" role="tabpanel">
        <!-- Google SSO -->
        <div class="lp-glass-card mb-4" style="border-radius:16px; padding:25px;">
          <div style="display:flex; align-items:center; gap:15px; border-bottom:1px solid var(--glass-border); padding-bottom:15px; margin-bottom:20px;">
            <div style="width:44px; height:44px; border-radius:12px; background:rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:center; font-size:20px;">
              <i class="bi bi-google text-danger"></i>
            </div>
            <div style="flex:1;">
              <h5 style="font-weight:700; margin:0; color:var(--text-primary); font-size:15px;">Google OAuth</h5>
              <p style="color:var(--text-muted); margin:2px 0 0 0; font-size:11px;">Sign in with Google account</p>
            </div>
            <div class="form-check form-switch" style="margin:0;">
              <input class="form-check-input" type="checkbox" id="googleEnabled" data-provider="google" style="width:40px; height:20px; cursor:pointer;">
            </div>
          </div>
          <div id="googleConfigFields" style="display:flex; flex-direction:column; gap:14px;">
            <div class="row g-3">
              <div class="col-12 col-md-6">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Client ID</label>
                  <input type="text" id="googleClientId" class="lp-input font-mono" placeholder="xxxxxxxxxx-xxxxxxxxxxxx.apps.googleusercontent.com" style="font-size:12px;">
                </div>
              </div>
              <div class="col-12 col-md-6">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Client Secret</label>
                  <input type="password" id="googleClientSecret" class="lp-input font-mono" placeholder="GOCSPX-xxxxxxxxxxxxxxxxxxxxxx" style="font-size:12px;">
                </div>
              </div>
            </div>
            <div class="lp-form-group mb-0">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Redirect URI</label>
              <input type="text" id="googleRedirectUri" class="lp-input font-mono" readonly style="font-size:12px; opacity:0.8; cursor:not-allowed;">
            </div>
          </div>
        </div>

        <!-- GitHub SSO -->
        <div class="lp-glass-card mb-4" style="border-radius:16px; padding:25px;">
          <div style="display:flex; align-items:center; gap:15px; border-bottom:1px solid var(--glass-border); padding-bottom:15px; margin-bottom:20px;">
            <div style="width:44px; height:44px; border-radius:12px; background:rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:center; font-size:20px;">
              <i class="bi bi-github"></i>
            </div>
            <div style="flex:1;">
              <h5 style="font-weight:700; margin:0; color:var(--text-primary); font-size:15px;">GitHub OAuth</h5>
              <p style="color:var(--text-muted); margin:2px 0 0 0; font-size:11px;">Sign in with GitHub account</p>
            </div>
            <div class="form-check form-switch" style="margin:0;">
              <input class="form-check-input" type="checkbox" id="githubEnabled" data-provider="github" style="width:40px; height:20px; cursor:pointer;">
            </div>
          </div>
          <div id="githubConfigFields" style="display:flex; flex-direction:column; gap:14px;">
            <div class="row g-3">
              <div class="col-12 col-md-6">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Client ID</label>
                  <input type="text" id="githubClientId" class="lp-input font-mono" placeholder="Iv1.xxxxxxxxxxxxxxx" style="font-size:12px;">
                </div>
              </div>
              <div class="col-12 col-md-6">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Client Secret</label>
                  <input type="password" id="githubClientSecret" class="lp-input font-mono" placeholder="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx" style="font-size:12px;">
                </div>
              </div>
            </div>
            <div class="lp-form-group mb-0">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Redirect URI</label>
              <input type="text" id="githubRedirectUri" class="lp-input font-mono" readonly style="font-size:12px; opacity:0.8; cursor:not-allowed;">
            </div>
          </div>
        </div>

        <!-- Save SSO Button -->
        <div style="display:flex; gap:10px;">
          <button class="btn-lp btn-lp-primary flex-fill" onclick="AuthConfig.saveSSO()" style="padding:10px; font-weight:600; font-size:13px;">
            <i class="bi bi-check2-circle me-1"></i> Save SSO Configuration
          </button>
          <button class="btn-lp btn-lp-ghost" onclick="AuthConfig.loadSSO()" title="Refresh" style="width:44px; padding:0;">
            <i class="bi bi-arrow-clockwise"></i>
          </button>
        </div>
      </div>

      <!-- ── LDAP Panel ── -->
      <div class="tab-pane fade" id="ldap-panel" role="tabpanel">
        <div class="lp-glass-card" style="border-radius:16px; padding:25px;">
          <div style="display:flex; align-items:center; gap:15px; border-bottom:1px solid var(--glass-border); padding-bottom:15px; margin-bottom:20px;">
            <div style="width:44px; height:44px; border-radius:12px; background:rgba(255,255,255,0.05); display:flex; align-items:center; justify-content:center; font-size:20px;">
              <i class="bi bi-building text-primary"></i>
            </div>
            <div style="flex:1;">
              <h5 style="font-weight:700; margin:0; color:var(--text-primary); font-size:15px;">LDAP / Active Directory</h5>
              <p style="color:var(--text-muted); margin:2px 0 0 0; font-size:11px;">Enterprise directory authentication</p>
            </div>
            <div class="form-check form-switch" style="margin:0;">
              <input class="form-check-input" type="checkbox" id="ldapEnabled" style="width:40px; height:20px; cursor:pointer;">
            </div>
          </div>

          <div id="ldapConfigFields" style="display:flex; flex-direction:column; gap:14px;">
            <div class="row g-3">
              <div class="col-12 col-md-8">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">LDAP Server URL</label>
                  <input type="text" id="ldapUrl" class="lp-input font-mono" placeholder="ldap://ldap.example.com:389" style="font-size:12px;">
                </div>
              </div>
              <div class="col-12 col-md-4">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">TLS</label>
                  <div style="display:flex; align-items:center; gap:10px; padding-top:5px;">
                    <div class="form-check form-switch mb-0">
                      <input class="form-check-input" type="checkbox" id="ldapTls" style="width:36px; height:18px; cursor:pointer;">
                    </div>
                    <span style="font-size:12px; color:var(--text-secondary);">Enable TLS</span>
                  </div>
                </div>
              </div>
            </div>

            <div class="row g-3">
              <div class="col-12 col-md-6">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Bind DN (Service Account)</label>
                  <input type="text" id="ldapBindDn" class="lp-input font-mono" placeholder="cn=admin,dc=example,dc=com" style="font-size:12px;">
                </div>
              </div>
              <div class="col-12 col-md-6">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Bind Password</label>
                  <input type="password" id="ldapBindPassword" class="lp-input font-mono" placeholder="Service account password" style="font-size:12px;">
                </div>
              </div>
            </div>

            <div class="lp-form-group mb-0">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Base DN</label>
              <input type="text" id="ldapBaseDn" class="lp-input font-mono" placeholder="dc=example,dc=com" style="font-size:12px;">
            </div>

            <div class="lp-form-group mb-0">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">User Search Filter</label>
              <input type="text" id="ldapUserFilter" class="lp-input font-mono" placeholder="(uid={{username}})" style="font-size:12px;">
              <small class="text-muted" style="font-size:10px; margin-top:4px; display:block;">Use <code>{{username}}</code> as placeholder for the login username.</small>
            </div>

            <div class="row g-3">
              <div class="col-12 col-md-4">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Username Attribute</label>
                  <input type="text" id="ldapUsernameAttr" class="lp-input font-mono" placeholder="uid" style="font-size:12px;">
                </div>
              </div>
              <div class="col-12 col-md-4">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Email Attribute</label>
                  <input type="text" id="ldapEmailAttr" class="lp-input font-mono" placeholder="mail" style="font-size:12px;">
                </div>
              </div>
              <div class="col-12 col-md-4">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Display Name Attr.</label>
                  <input type="text" id="ldapDisplayNameAttr" class="lp-input font-mono" placeholder="displayName" style="font-size:12px;">
                </div>
              </div>
            </div>

            <div class="row g-3">
              <div class="col-12 col-md-6">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">First Name Attribute</label>
                  <input type="text" id="ldapFirstNameAttr" class="lp-input font-mono" placeholder="givenName" style="font-size:12px;">
                </div>
              </div>
              <div class="col-12 col-md-6">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Last Name Attribute</label>
                  <input type="text" id="ldapLastNameAttr" class="lp-input font-mono" placeholder="sn" style="font-size:12px;">
                </div>
              </div>
            </div>

            <div class="row g-3">
              <div class="col-12 col-md-6">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Default Role (Auto-create)</label>
                  <input type="text" id="ldapDefaultRole" class="lp-input font-mono" placeholder="read_only" style="font-size:12px;">
                </div>
              </div>
              <div class="col-12 col-md-6">
                <div class="lp-form-group mb-0">
                  <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Auto-Create Users</label>
                  <div style="display:flex; align-items:center; gap:10px; padding-top:5px;">
                    <div class="form-check form-switch mb-0">
                      <input class="form-check-input" type="checkbox" id="ldapAutoCreate" checked style="width:36px; height:18px; cursor:pointer;">
                    </div>
                    <span style="font-size:12px; color:var(--text-secondary);">Auto-create on first login</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- LDAP Actions -->
          <div style="display:flex; gap:10px; margin-top:20px; padding-top:20px; border-top:1px solid var(--glass-border); flex-wrap:wrap;">
            <button class="btn-lp btn-lp-primary flex-fill" onclick="AuthConfig.saveLDAP()" style="padding:10px; font-weight:600; font-size:13px;">
              <i class="bi bi-check2-circle me-1"></i> Save LDAP Configuration
            </button>
            <button class="btn-lp btn-lp-info" onclick="AuthConfig.testLDAP()" style="padding:10px 16px; font-weight:600; font-size:12px;">
              <i class="bi bi-plug me-1"></i> Test Connection
            </button>
            <button class="btn-lp btn-lp-ghost" onclick="AuthConfig.loadLDAP()" title="Refresh" style="width:44px; padding:0;">
              <i class="bi bi-arrow-clockwise"></i>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/settings/auth.js?v=<%= Date.now() %>"></script>
