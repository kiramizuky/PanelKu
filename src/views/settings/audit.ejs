<div class="row g-4">
  <!-- Left Side: Navigation Sidebar -->
  <div class="col-12 col-lg-4">
    <div class="settings-sidebar">
      <div class="settings-sidebar-header">
        <div class="settings-avatar">
          <i class="bi bi-journal-text"></i>
        </div>
        <h5 class="settings-sidebar-name">Audit Center</h5>
        <p class="settings-sidebar-sub">Security &amp; Command Audits</p>
      </div>

      <!-- Navigation List -->
      <div class="settings-nav">
        <a href="/settings/profile" class="settings-nav-item">
          <i class="bi bi-person"></i> My Profile
        </a>
        <a href="/settings/users" class="settings-nav-item">
          <i class="bi bi-people"></i> Users
        </a>
        <a href="/settings/roles" class="settings-nav-item">
          <i class="bi bi-shield-lock"></i> Roles &amp; Permissions
        </a>
        <a href="/settings/panel" class="settings-nav-item">
          <i class="bi bi-arrow-repeat"></i> Panel Update
        </a>
        <a href="/settings/audit" class="settings-nav-item active">
          <i class="bi bi-journal-text-fill"></i> Audit Log
        </a>
        <a href="/settings/changelog" class="settings-nav-item">
          <i class="bi bi-file-earmark-text"></i> Changelog
        </a>
      </div>
    </div>
  </div>

  <!-- Right Side: Stats, Charts, and Logs List -->
  <div class="col-12 col-lg-8 settings-content">
    
    <!-- Stats Row -->
    <div class="audit-stat-cards">
      <div class="audit-stat-card" style="--stat-color: var(--accent-primary);">
        <i class="bi bi-shield-check audit-stat-icon-bg"></i>
        <div class="audit-stat-label">Login Events (7d)</div>
        <div id="statTotalLogins" class="audit-stat-value">0</div>
      </div>
      <div class="audit-stat-card" style="--stat-color: var(--accent-info);">
        <i class="bi bi-terminal audit-stat-icon-bg"></i>
        <div class="audit-stat-label">Terminal Cmds (7d)</div>
        <div id="statTotalCmds" class="audit-stat-value">0</div>
      </div>
      <div class="audit-stat-card" style="--stat-color: var(--accent-success);">
        <i class="bi bi-activity audit-stat-icon-bg"></i>
        <div class="audit-stat-label">Most Active Cmd</div>
        <div id="statTopCmd" class="audit-stat-value text-truncate">-</div>
      </div>
    </div>

    <!-- Charts Row -->
    <div class="audit-charts">
      <div class="audit-chart-card">
        <div class="audit-chart-label" style="--chart-accent: var(--accent-primary);">
          <span class="chart-accent-bar" style="background: var(--accent-primary);"></span>
          Login Histogram
        </div>
        <div class="audit-chart-wrap">
          <canvas id="chartLogins"></canvas>
        </div>
      </div>
      <div class="audit-chart-card">
        <div class="audit-chart-label" style="--chart-accent: var(--accent-info);">
          <span class="chart-accent-bar" style="background: var(--accent-info);"></span>
          Terminal Commands
        </div>
        <div class="audit-chart-wrap">
          <canvas id="chartCommands"></canvas>
        </div>
      </div>
    </div>

    <!-- Audit Logs List Card -->
    <div class="audit-table-card">
      <div class="audit-table-header">
        <h5 class="audit-table-title">
          <i class="bi bi-list-task"></i> Audit Trail
        </h5>
        <div class="audit-table-filters">
          <select id="logTypeFilter" class="audit-filter-select" onchange="AuditPage.filterLogs()">
            <option value="all">All Logs</option>
            <option value="system">System Logs</option>
            <option value="terminal">Terminal/CLI</option>
          </select>
          <input type="text" id="logSearch" class="audit-filter-search" placeholder="Search logs..." oninput="AuditPage.filterLogs()">
        </div>
      </div>

      <div class="audit-table-scroll">
        <table class="audit-data-table">
          <colgroup>
            <col style="width: 145px;"><!-- Time -->
            <col style="width: 100px;"><!-- User -->
            <col style="width: 85px;"> <!-- Type -->
            <col style="width: 170px;"><!-- Action -->
            <col>                      <!-- Details -->
          </colgroup>
          <thead>
            <tr>
              <th>Time</th>
              <th>User</th>
              <th>Type</th>
              <th>Action</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody id="auditLogsTableBody">
            <tr>
              <td colspan="5" class="text-center py-4 text-muted">
                <span class="spinner-border spinner-border-sm me-2" style="width: 12px; height: 12px;"></span> Loading logs...
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="/js/settings/audit.js?v=<%= Date.now() %>"></script>
