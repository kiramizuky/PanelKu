<div class="row g-4">
  <!-- Left Side: Navigation Sidebar -->
  <div class="col-12 col-lg-4">
    <div class="lp-glass-card p-0" style="border-radius:16px; overflow:hidden; position:relative;">
      <div style="position:relative; padding:25px; text-align:center; border-bottom:1px solid var(--glass-border);">
        <div style="position:absolute; top:0; left:0; width:100%; height:100%; background:linear-gradient(135deg, var(--accent-primary), var(--accent-info)); opacity:0.08; z-index:1;"></div>
        <div style="position:relative; z-index:2;">
          <div style="position:relative; display:inline-block; margin-bottom:12px;">
            <div style="width:64px; height:64px; border-radius:50%; background:linear-gradient(135deg, var(--accent-primary), var(--accent-info)); display:flex; align-items:center; justify-content:center; box-shadow:0 4px 12px rgba(99,102,241,0.25); border:3px solid rgba(255,255,255,0.08);">
              <i class="bi bi-journal-text" style="font-size:28px; color:#fff;"></i>
            </div>
          </div>
          <h5 style="font-weight:700; margin:0 0 2px; color:var(--text-primary); font-size:16px;">Audit Center</h5>
          <p style="font-size:11px; color:var(--text-muted); margin:0;">Security & Command Audits</p>
        </div>
      </div>

      <!-- Navigation List -->
      <div class="list-group list-group-flush">
        <a href="/settings/profile" class="list-group-item list-group-item-action d-flex align-items-center gap-3" style="background:transparent; color:var(--text-secondary); border-bottom:1px solid var(--glass-border); padding:14px 20px; transition:all 0.2s; font-size:13px;">
          <i class="bi bi-person"></i> My Profile
        </a>
        <a href="/settings/users" class="list-group-item list-group-item-action d-flex align-items-center gap-3" style="background:transparent; color:var(--text-secondary); border-bottom:1px solid var(--glass-border); padding:14px 20px; transition:all 0.2s; font-size:13px;">
          <i class="bi bi-people"></i> Users
        </a>
        <a href="/settings/roles" class="list-group-item list-group-item-action d-flex align-items-center gap-3" style="background:transparent; color:var(--text-secondary); border-bottom:1px solid var(--glass-border); padding:14px 20px; transition:all 0.2s; font-size:13px;">
          <i class="bi bi-shield-lock"></i> Roles & Permissions
        </a>
        <a href="/settings/panel" class="list-group-item list-group-item-action d-flex align-items-center gap-3" style="background:transparent; color:var(--text-secondary); border-bottom:1px solid var(--glass-border); padding:14px 20px; transition:all 0.2s; font-size:13px;">
          <i class="bi bi-arrow-repeat"></i> Panel Update
        </a>
        <a href="/settings/audit" class="list-group-item list-group-item-action d-flex align-items-center gap-3" style="background:rgba(99,102,241,0.08); color:var(--accent-primary); border:none; padding:14px 20px; font-weight:600; font-size:13px;">
          <i class="bi bi-journal-text-fill"></i> Audit Log
        </a>
      </div>
    </div>
  </div>

  <!-- Right Side: Stats, Charts, and Logs List -->
  <div class="col-12 col-lg-8">
    <!-- Stats Row -->
    <div class="row g-3 mb-4">
      <div class="col-12 col-md-4">
        <div class="lp-glass-card p-3" style="border-radius:12px;">
          <span style="font-size:11px; color:var(--text-muted); text-transform:uppercase; font-weight:700;">Login Events (7d)</span>
          <h3 id="statTotalLogins" class="mt-2 mb-0 font-mono" style="font-weight:700; color:#fff;">0</h3>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="lp-glass-card p-3" style="border-radius:12px;">
          <span style="font-size:11px; color:var(--text-muted); text-transform:uppercase; font-weight:700;">Terminal Cmds (7d)</span>
          <h3 id="statTotalCmds" class="mt-2 mb-0 font-mono" style="font-weight:700; color:#38bdf8;">0</h3>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="lp-glass-card p-3" style="border-radius:12px;">
          <span style="font-size:11px; color:var(--text-muted); text-transform:uppercase; font-weight:700;">Most Active Cmd</span>
          <h3 id="statTopCmd" class="mt-2 mb-0 font-mono text-truncate" style="font-weight:700; color:var(--accent-success);">-</h3>
        </div>
      </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-3 mb-4">
      <div class="col-12 col-md-6">
        <div class="lp-glass-card p-4" style="border-radius:12px; height: 260px;">
          <h6 style="font-size:12px; font-weight:700; margin-bottom:15px; color:var(--text-primary);">LOGIN HISTOGRAM</h6>
          <div style="height: 170px; position:relative;">
            <canvas id="chartLogins"></canvas>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="lp-glass-card p-4" style="border-radius:12px; height: 260px;">
          <h6 style="font-size:12px; font-weight:700; margin-bottom:15px; color:var(--text-primary);">TERMINAL COMMANDS</h6>
          <div style="height: 170px; position:relative;">
            <canvas id="chartCommands"></canvas>
          </div>
        </div>
      </div>
    </div>

    <!-- Audit Logs List Card -->
    <div class="lp-glass-card p-4" style="border-radius:16px;">
      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h5 style="font-weight:700; margin:0; color:var(--text-primary);"><i class="bi bi-list-task me-2 text-primary"></i>Audit Trail</h5>
        <div class="d-flex gap-2">
          <select id="logTypeFilter" class="lp-input py-1" style="width: 130px; font-size:12px; height:32px;" onchange="AuditPage.filterLogs()">
            <option value="all">All Logs</option>
            <option value="system">System Logs</option>
            <option value="terminal">Terminal Logs</option>
          </select>
          <input type="text" id="logSearch" class="lp-input py-1" style="width: 160px; font-size:12px; height:32px;" placeholder="Search logs..." oninput="AuditPage.filterLogs()">
        </div>
      </div>

      <div class="table-responsive" style="min-height: 200px; max-height: 450px; overflow-y: auto; border: 1px solid var(--glass-border); border-radius: 10px;">
        <table class="lp-table" style="font-size:12px; margin:0; table-layout: fixed; width: 100%;">
          <colgroup>
            <col style="width: 145px;"><!-- Time -->
            <col style="width: 100px;"><!-- User -->
            <col style="width: 85px;"> <!-- Type -->
            <col style="width: 180px;"><!-- Action -->
            <col>                      <!-- Details (fills remaining) -->
          </colgroup>
          <thead style="position: sticky; top: 0; z-index: 2; background: var(--bg-secondary, #1a1a2e);">
            <tr>
              <th>Time</th>
              <th>User</th>
              <th>Type</th>
              <th>Action</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody id="auditLogsTableBody">
            <tr>
              <td colspan="5" class="text-center py-4 text-muted">Loading logs...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script src="/js/settings/audit.js?v=<%= Date.now() %>"></script>
