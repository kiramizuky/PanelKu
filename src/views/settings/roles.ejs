<div class="row g-4">
  <!-- Left Side: Navigation & Profile Card (Unified) -->
  <div class="col-12 col-lg-4">
    <div class="settings-sidebar">
      <!-- Header Banner / Profile Area -->
      <div class="settings-sidebar-header">
        <!-- Avatar Ring -->
        <div style="position:relative; display:inline-block;">
          <div class="settings-avatar" style="margin:0 auto 10px;">
            <i class="bi bi-person"></i>
          </div>
          <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-dark rounded-circle" style="width:10px; height:10px;" title="Online Status"></span>
        </div>
        <h5 id="profileCardName" class="settings-sidebar-name">Loading...</h5>
        <p id="profileCardEmail" class="settings-sidebar-sub">Loading...</p>
        <span id="profileCardBadge" class="lp-badge lp-badge-success" style="text-transform:uppercase; font-size:9px; font-weight:600; padding:4px 8px; border-radius:8px;">ROLE</span>
      </div>

      <!-- Navigation List -->
      <div class="settings-nav">
        <a href="/settings/profile" class="settings-nav-item">
          <i class="bi bi-person"></i> My Profile
        </a>
        <a href="/settings/users" class="settings-nav-item">
          <i class="bi bi-people"></i> Users
        </a>
        <a href="/settings/roles" class="settings-nav-item active">
          <i class="bi bi-shield-lock-fill"></i> Roles &amp; Permissions
        </a>
        <a href="/settings/panel" class="settings-nav-item">
          <i class="bi bi-arrow-repeat"></i> Panel Update
        </a>
        <a href="/settings/audit" class="settings-nav-item">
          <i class="bi bi-journal-text"></i> Audit Log
        </a>
        <a href="/settings/changelog" class="settings-nav-item">
          <i class="bi bi-file-earmark-text"></i> Changelog
        </a>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-8">
    <div class="lp-glass-card">
      <div class="lp-card-header" style="border-bottom:1px solid var(--glass-border);display:flex;justify-content:space-between;align-items:center;padding-bottom:15px;margin-bottom:15px;">
        <h3 class="lp-card-title m-0">Roles Management</h3>
        <button class="btn-lp btn-lp-primary btn-lp-sm" onclick="RolesPage.showCreateModal()"><i class="bi bi-shield-plus"></i> Add Role</button>
      </div>
      <div class="lp-card-body" style="padding:0;overflow-x:auto;">
        <table class="lp-table">
          <thead>
            <tr>
              <th>Role Name</th>
              <th>Description</th>
              <th style="text-align:right">Actions</th>
            </tr>
          </thead>
          <tbody id="rolesTableBody">
            <tr><td colspan="3" style="text-align:center;color:var(--text-muted);padding:20px;">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Add/Edit Role Modal -->
<div class="modal fade" id="roleModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content lp-glass-card">
      <div class="modal-header border-0">
        <h5 class="modal-title font-mono" id="roleModalTitle" style="font-size:14px">Add Role</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="roleForm" onsubmit="RolesPage.saveRole(event)">
        <div class="modal-body">
          <input type="hidden" id="roleId">
          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label class="lp-label">Role Name</label>
              <input type="text" id="roleName" class="lp-input" placeholder="e.g. support" required>
            </div>
            <div class="col-md-6">
              <label class="lp-label">Description</label>
              <input type="text" id="roleDesc" class="lp-input" placeholder="Role description">
            </div>
          </div>
          
          <h6 style="font-weight:600;margin-bottom:15px;font-size:13px;color:var(--text-secondary);border-bottom:1px solid var(--glass-border);padding-bottom:8px;">Permissions Map</h6>
          <div id="permissionsContainer"></div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary">Save Role</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/settings/roles.js"></script>
