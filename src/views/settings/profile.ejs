<div class="row g-4">
  <!-- Left Side: Navigation & Profile Card (Unified) -->
  <div class="col-12 col-lg-4">
    <div class="settings-sidebar">
      <!-- Header Banner / Profile Area -->
      <div class="settings-sidebar-header">
        <!-- Avatar Ring -->
        <div style="position:relative; display:inline-block;">
          <div class="settings-avatar" style="margin:0 auto 10px;">
            <i class="bi bi-person"></i>
          </div>
          <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-dark rounded-circle" style="width:10px; height:10px;" title="Online Status"></span>
        </div>
        <h5 id="profileCardName" class="settings-sidebar-name">Loading...</h5>
        <p id="profileCardEmail" class="settings-sidebar-sub">Loading...</p>
        <span id="profileCardBadge" class="lp-badge lp-badge-success" style="text-transform:uppercase; font-size:9px; font-weight:600; padding:4px 8px; border-radius:8px;">ROLE</span>
      </div>

      <!-- Navigation List -->
      <div class="settings-nav">
        <a href="/settings/profile" class="settings-nav-item active">
          <i class="bi bi-person-fill"></i> My Profile
        </a>
        <a href="/settings/users" class="settings-nav-item">
          <i class="bi bi-people"></i> Users
        </a>
        <a href="/settings/roles" class="settings-nav-item">
          <i class="bi bi-shield-lock"></i> Roles &amp; Permissions
        </a>
        <a href="/settings/panel" class="settings-nav-item">
          <i class="bi bi-arrow-repeat"></i> Panel Update
        </a>
        <a href="/settings/audit" class="settings-nav-item">
          <i class="bi bi-journal-text"></i> Audit Log
        </a>
      </div>
    </div>
  </div>

  <!-- Right Side: Account Details & Security -->
  <div class="col-12 col-lg-8">
    <div class="row g-4">
      <!-- Account Details Card -->
      <div class="col-12 col-md-6">
        <div class="lp-glass-card h-100 mb-0" style="border-radius:16px; padding:25px; display:flex; flex-direction:column;">
          <div style="border-bottom:1px solid var(--glass-border); padding-bottom:12px; margin-bottom:20px;">
            <h5 style="font-weight:700; margin:0; color:var(--text-primary);"><i class="bi bi-shield-check me-2 text-primary"></i>Account Details</h5>
          </div>
          <div style="display:flex; flex-direction:column; gap:15px; flex:1; justify-content:center;">
            <div class="lp-form-group mb-0">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Username</label>
              <div style="position:relative;">
                <span style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted);"><i class="bi bi-person"></i></span>
                <input type="text" id="profUsername" class="lp-input" readonly style="opacity:0.75; padding-left:38px; cursor:not-allowed;">
              </div>
            </div>
            <div class="lp-form-group mb-0">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Email Address</label>
              <div style="position:relative;">
                <span style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted);"><i class="bi bi-envelope"></i></span>
                <input type="email" id="profEmail" class="lp-input" readonly style="opacity:0.75; padding-left:38px; cursor:not-allowed;">
              </div>
            </div>
            <div class="lp-form-group mb-0">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">Assigned System Role</label>
              <div style="position:relative;">
                <span style="position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--text-muted);"><i class="bi bi-shield-lock"></i></span>
                <input type="text" id="profRole" class="lp-input" readonly style="opacity:0.75; padding-left:38px; text-transform:uppercase; cursor:not-allowed;">
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- API Credentials Card -->
      <div class="col-12 col-md-6">
        <div class="lp-glass-card h-100 mb-0" style="border-radius:16px; padding:25px; display:flex; flex-direction:column;">
          <div style="border-bottom:1px solid var(--glass-border); padding-bottom:12px; margin-bottom:20px; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
            <h5 style="font-weight:700; margin:0; color:var(--text-primary);"><i class="bi bi-code-slash me-2 text-info"></i>API Credentials</h5>
            <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="ProfilePage.regenerateApiKey()" id="btnRegenApiKey" style="font-size:11px; padding:4px 8px;"><i class="bi bi-arrow-clockwise"></i> Generate Key</button>
          </div>
          <div style="display:flex; flex-direction:column; gap:15px; flex:1; justify-content:center;">
            <div class="lp-form-group mb-0">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">X-API-Key Header Value</label>
              <div style="display:flex; gap:8px;">
                <input type="password" id="profApiKey" class="lp-input font-mono" readonly style="opacity:0.75; cursor:not-allowed;" value="••••••••••••••••••••••••••••••••">
                <button class="btn-lp btn-lp-ghost" onclick="ProfilePage.toggleApiKeyVisibility()" id="btnToggleApiKey" title="Show/Hide" disabled style="padding: 0 10px;"><i class="bi bi-eye"></i></button>
                <button class="btn-lp btn-lp-primary" onclick="ProfilePage.copyApiKey()" id="btnCopyApiKey" title="Copy" disabled style="padding: 0 10px;"><i class="bi bi-clipboard"></i></button>
              </div>
            </div>
            <small class="text-muted d-block" style="font-size:10.5px; line-height:1.4;">Note: For security, the key is hidden by default. Click "Generate Key" to create a new token.</small>
          </div>
        </div>
      </div>

      <!-- Two-Factor Authentication (2FA) Card -->
      <div class="col-12 col-md-6">
        <div class="lp-glass-card h-100 mb-0" style="border-radius:16px; padding:25px; display:flex; flex-direction:column;">
          <div style="border-bottom:1px solid var(--glass-border); padding-bottom:12px; margin-bottom:20px; display:flex; justify-content:space-between; align-items:center;">
            <h5 style="font-weight:700; margin:0; color:var(--text-primary);"><i class="bi bi-shield-lock-fill me-2 text-success"></i>Two-Factor Auth (2FA)</h5>
          </div>
          <div style="display:flex; flex-direction:column; gap:15px; flex:1; justify-content:center;">
            <div id="2faStatusContainer" class="d-flex align-items-center justify-content-between p-3 rounded" style="background:rgba(0,0,0,0.2); border:1px solid var(--glass-border);">
              <div>
                <span class="d-block" style="font-size:12px; font-weight:600; color:var(--text-primary);">Status 2FA</span>
                <span id="2faBadge" class="lp-badge lp-badge-danger mt-1" style="font-size:10px;">Disabled</span>
              </div>
              <button id="btnToggle2FA" class="btn-lp btn-lp-primary" onclick="ProfilePage.toggle2FA()" style="font-size:12px; padding:6px 12px;">Enable 2FA</button>
            </div>
            
            <!-- Setup container (hidden by default) -->
            <div id="2faSetupContainer" style="display:none; background:rgba(0,0,0,0.2); padding:15px; border-radius:10px; border:1px solid var(--glass-border);">
              <p class="text-muted" style="font-size:11px; margin-bottom:10px;">Scan the QR code or enter the secret key manually in your authenticator app (Google Authenticator, Authy, etc.):</p>
              <div class="text-center mb-3">
                <img id="2faQrCode" src="" alt="2FA QR Code" style="background:white; padding:8px; border-radius:8px; display:inline-block; width:120px; height:120px; margin: 0 auto;">
              </div>
              <div class="mb-3">
                <label class="lp-label" style="font-size:11px;">Manual Secret Key</label>
                <input type="text" id="2faSecretKey" class="lp-input font-mono" readonly style="font-size:12px; text-align:center; background: rgba(0,0,0,0.2); height: 32px; padding: 0;">
              </div>
              <div class="mb-3">
                <label class="lp-label" style="font-size:11px;">Enter Authenticator Code</label>
                <input type="text" id="2faOtpCode" class="lp-input font-mono" placeholder="123456" style="text-align:center; height:32px;">
              </div>
              <button class="btn-lp btn-lp-primary w-100" onclick="ProfilePage.confirmEnable2FA()" style="font-size:12px; height:36px; padding:0;">Confirm & Enable</button>
            </div>
          </div>
        </div>
      </div>

      <!-- OpenClaw AI Copilot Card -->
      <div class="col-12 col-md-6">
        <div class="lp-glass-card h-100 mb-0" style="border-radius:16px; padding:25px; display:flex; flex-direction:column;">
          <div style="border-bottom:1px solid var(--glass-border); padding-bottom:12px; margin-bottom:20px; display:flex; justify-content:space-between; align-items:center;">
            <h5 style="font-weight:700; margin:0; color:var(--text-primary);"><i class="bi bi-robot me-2 text-info"></i>OpenClaw AI Settings</h5>
          </div>
          <div style="display:flex; flex-direction:column; gap:15px; flex:1; justify-content:center;">
            <div class="lp-form-group mb-0">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">AI Provider</label>
              <select id="aiProvider" class="lp-input" onchange="ProfilePage.toggleAiFields()">
                <option value="built-in">Built-in (Heuristics / Offline)</option>
                <option value="openai">OpenAI API</option>
                <option value="gemini">Google Gemini API</option>
                <option value="openrouter">OpenRouter API</option>
              </select>
            </div>
            
            <div id="aiKeyGroup" class="lp-form-group mb-0" style="display:none;">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">API Key</label>
              <input type="password" id="aiApiKey" class="lp-input font-mono" placeholder="sk-...">
            </div>

            <div id="aiModelGroup" class="lp-form-group mb-0" style="display:none;">
              <label class="lp-label" style="font-size:11px; font-weight:600; color:var(--text-muted);">AI Model</label>
              <input type="text" id="aiModel" class="lp-input font-mono" placeholder="gpt-4o-mini">
            </div>

            <button class="btn-lp btn-lp-primary w-100" onclick="ProfilePage.saveAiSettings()" style="font-size:12px; height:36px; padding:0;">Save AI Settings</button>
          </div>
        </div>
      </div>

      <!-- Change Password Card -->
      <div class="col-12">
        <div class="lp-glass-card" style="border-radius:16px; padding:25px;">
          <div style="border-bottom:1px solid var(--glass-border); padding-bottom:12px; margin-bottom:20px;">
            <h5 style="font-weight:700; margin:0; color:var(--text-primary);"><i class="bi bi-key me-2 text-warning"></i>Security Settings</h5>
          </div>
          <form onsubmit="ProfilePage.changePassword(event)" class="row g-3">
            <div class="col-12">
              <div class="lp-form-group mb-0">
                <label class="lp-label" style="font-size:11px; font-weight:600;">Current Password</label>
                <input type="password" id="currentPassword" class="lp-input" placeholder="Type current password" required>
              </div>
            </div>
            <div class="col-12 col-md-6">
              <div class="lp-form-group mb-0">
                <label class="lp-label" style="font-size:11px; font-weight:600;">New Password</label>
                <input type="password" id="newPassword" class="lp-input" placeholder="Min. 8 characters" required minlength="8">
              </div>
            </div>
            <div class="col-12 col-md-6">
              <div class="lp-form-group mb-0">
                <label class="lp-label" style="font-size:11px; font-weight:600;">Confirm New Password</label>
                <input type="password" id="confirmPassword" class="lp-input" placeholder="Verify password" required minlength="8">
              </div>
            </div>
            <div class="col-12 mt-4">
              <button type="submit" class="btn-lp btn-lp-primary w-100" style="padding:10px; font-weight:600; font-size:13px;"><i class="bi bi-check2-circle me-1"></i> Update Security Credentials</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/settings/profile.js?v=<%= Date.now() %>"></script>
