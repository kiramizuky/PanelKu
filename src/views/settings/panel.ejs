<div class="row g-4">
  <!-- Left Side: Navigation & Profile Card (Unified) -->
  <div class="col-12 col-lg-4">
    <div class="settings-sidebar">
      <!-- Header Banner / Profile Area -->
      <div class="settings-sidebar-header">
        <!-- Avatar Ring -->
        <div style="position:relative; display:inline-block;">
          <div class="settings-avatar" style="margin:0 auto 10px;">
            <i class="bi bi-person"></i>
          </div>
          <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-dark rounded-circle" style="width:10px; height:10px;" title="Online Status"></span>
        </div>
        <h5 id="profileCardName" class="settings-sidebar-name">Loading...</h5>
        <p id="profileCardEmail" class="settings-sidebar-sub">Loading...</p>
        <span id="profileCardBadge" class="lp-badge lp-badge-success" style="text-transform:uppercase; font-size:9px; font-weight:600; padding:4px 8px; border-radius:8px;">ROLE</span>
      </div>

      <!-- Navigation List -->
      <div class="settings-nav">
        <a href="/settings/profile" class="settings-nav-item">
          <i class="bi bi-person"></i> My Profile
        </a>
        <a href="/settings/users" class="settings-nav-item">
          <i class="bi bi-people"></i> Users
        </a>
        <a href="/settings/roles" class="settings-nav-item">
          <i class="bi bi-shield-lock"></i> Roles &amp; Permissions
        </a>
        <a href="/settings/panel" class="settings-nav-item active">
          <i class="bi bi-arrow-repeat"></i> Panel Update
        </a>
        <a href="/settings/audit" class="settings-nav-item">
          <i class="bi bi-journal-text"></i> Audit Log
        </a>
        <a href="/settings/changelog" class="settings-nav-item">
          <i class="bi bi-file-earmark-text"></i> Changelog
        </a>
      </div>
    </div>
  </div>

  <!-- Content: 2 columns layout -->
  <div class="col-12 col-lg-8">
    <div class="row g-3">

      <!-- LEFT COLUMN -->
      <div class="col-12 col-lg-5 d-flex flex-column gap-3">

        <!-- Version Info Card -->
        <div class="lp-glass-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div>
              <div class="lp-card-title m-0" style="font-size:14px;">Panel Version</div>
              <div style="color:var(--text-secondary);font-size:12px;margin-top:2px;">Installation info</div>
            </div>
            <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="PanelPage.checkUpdate()" id="btnCheckUpdate" style="font-size:12px;">
              <i class="bi bi-arrow-repeat"></i> Check
            </button>
          </div>
          <div class="row g-2">
            <div class="col-6">
              <div style="background:var(--bg-tertiary);border-radius:10px;padding:12px;text-align:center;">
                <div style="font-size:10px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:6px;">Current</div>
                <div id="currentVersion" style="font-size:18px;font-weight:700;color:var(--accent-primary);font-family:monospace;">—</div>
              </div>
            </div>
            <div class="col-6">
              <div style="background:var(--bg-tertiary);border-radius:10px;padding:12px;text-align:center;">
                <div style="font-size:10px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:6px;">Latest</div>
                <div id="latestVersion" style="font-size:18px;font-weight:700;color:var(--text-primary);font-family:monospace;">—</div>
              </div>
            </div>
            <div class="col-12">
              <div style="background:var(--bg-tertiary);border-radius:10px;padding:10px 14px;display:flex;align-items:center;justify-content:space-between;">
                <span style="font-size:12px;color:var(--text-secondary);">Status</span>
                <span id="updateStatus">
                  <span class="lp-badge lp-badge-warning"><span class="lp-badge-dot"></span>Not Checked</span>
                </span>
              </div>
            </div>
          </div>
        </div>

        <!-- Auto-Update Card -->
        <div class="lp-glass-card">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
            <div>
              <div class="lp-card-title m-0" style="font-size:14px;">Auto-Update</div>
              <div style="color:var(--text-secondary);font-size:12px;margin-top:2px;">Scheduled panel updates</div>
            </div>
            <div class="form-check form-switch m-0">
              <input class="form-check-input" type="checkbox" id="autoUpdateToggle" onchange="PanelPage.toggleAutoUpdate()" style="width:38px;height:20px;cursor:pointer;">
            </div>
          </div>
          <div class="lp-form-group mb-2">
            <label class="lp-label" style="font-size:12px;">Frequency</label>
            <select id="autoUpdateFreq" class="lp-input" onchange="PanelPage.saveAutoUpdateConfig()" style="font-size:13px;">
              <option value="daily">Daily (midnight)</option>
              <option value="weekly">Weekly (Sunday)</option>
              <option value="manual">Manual Only</option>
            </select>
          </div>
          <div class="lp-form-group mb-0">
            <label class="lp-label" style="font-size:12px;">Last Updated</label>
            <input type="text" id="lastUpdatedAt" class="lp-input" readonly style="opacity:0.7;font-size:13px;" value="—">
          </div>
        </div>

      </div>

      <!-- RIGHT COLUMN -->
      <div class="col-12 col-lg-7">
        <div class="lp-glass-card h-100">
          <div style="margin-bottom:16px;">
            <div class="lp-card-title m-0" style="font-size:14px;">Panel Update</div>
            <div style="color:var(--text-secondary);font-size:12px;margin-top:2px;">Pull latest changes and restart</div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-7">
              <label class="lp-label" style="font-size:12px;">Method</label>
              <select id="updateMethod" class="lp-input" style="font-size:13px;">
                <option value="git">Git Pull (Recommended)</option>
                <option value="npm">NPM Update Only</option>
              </select>
            </div>
            <div class="col-5">
              <label class="lp-label" style="font-size:12px;">Branch</label>
              <input type="text" id="updateBranch" class="lp-input" value="main" placeholder="main" style="font-size:13px;">
            </div>
          </div>

          <div style="display:flex;gap:8px;margin-bottom:14px;">
            <button class="btn-lp btn-lp-primary btn-lp-sm" onclick="PanelPage.runUpdate()" id="btnUpdate">
              <i class="bi bi-cloud-download"></i> Update Panel
            </button>
            <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="PanelPage.restartPanel()" id="btnRestart">
              <i class="bi bi-arrow-clockwise"></i> Restart Only
            </button>
          </div>

          <label class="lp-label" style="font-size:12px;">Update Log</label>
          <div id="updateLog" style="background:var(--bg-tertiary);border:1px solid var(--glass-border);border-radius:10px;padding:12px;font-family:monospace;font-size:12px;color:var(--text-secondary);height:180px;overflow-y:auto;white-space:pre-wrap;line-height:1.6;">Ready. Click "Update Panel" to start.</div>
        </div>
      </div>

    </div>
  </div>
</div>

<script src="/js/settings/panel.js"></script>
