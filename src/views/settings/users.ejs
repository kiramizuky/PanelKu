<div class="row g-4">
  <!-- Left Side: Navigation & Profile Card (Unified) -->
  <div class="col-12 col-lg-4">
    <div class="lp-glass-card p-0" style="border-radius:16px; overflow:hidden; position:relative;">
      <!-- Header Banner / Profile Area -->
      <div style="position:relative; padding:25px; text-align:center; border-bottom:1px solid var(--glass-border);">
        <div style="position:absolute; top:0; left:0; width:100%; height:100%; background:linear-gradient(135deg, var(--accent-primary), var(--accent-info)); opacity:0.08; z-index:1;"></div>
        <div style="position:relative; z-index:2;">
          <!-- Avatar Ring -->
          <div style="position:relative; display:inline-block; margin-bottom:12px;">
            <div style="width:64px; height:64px; border-radius:50%; background:linear-gradient(135deg, var(--accent-primary), var(--accent-info)); display:flex; align-items:center; justify-content:center; box-shadow:0 4px 12px rgba(99,102,241,0.25); border:3px solid rgba(255,255,255,0.08);">
              <i class="bi bi-person" style="font-size:28px; color:#fff;"></i>
            </div>
            <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-dark rounded-circle" style="width:10px; height:10px;" title="Online Status"></span>
          </div>
          <h5 id="profileCardName" style="font-weight:700; margin:0 0 2px; color:var(--text-primary); font-size:16px;">Loading...</h5>
          <p id="profileCardEmail" style="font-size:12px; color:var(--text-muted); margin:0 0 10px;">Loading...</p>
          <span id="profileCardBadge" class="lp-badge lp-badge-success" style="text-transform:uppercase; font-size:9px; font-weight:600; letter-spacing:0.5px; padding:4px 8px; border-radius:8px;">ROLE</span>
        </div>
      </div>

      <!-- Navigation List -->
      <div class="list-group list-group-flush">
        <a href="/settings/profile" class="list-group-item list-group-item-action d-flex align-items-center gap-3" style="background:transparent; color:var(--text-secondary); border-bottom:1px solid var(--glass-border); padding:14px 20px; transition:all 0.2s; font-size:13px;">
          <i class="bi bi-person"></i> My Profile
        </a>
        <a href="/settings/users" class="list-group-item list-group-item-action d-flex align-items-center gap-3" style="background:rgba(99,102,241,0.08); color:var(--accent-primary); border-bottom:1px solid var(--glass-border); padding:14px 20px; font-weight:600; font-size:13px;">
          <i class="bi bi-people-fill"></i> Users
        </a>
        <a href="/settings/roles" class="list-group-item list-group-item-action d-flex align-items-center gap-3" style="background:transparent; color:var(--text-secondary); border-bottom:1px solid var(--glass-border); padding:14px 20px; transition:all 0.2s; font-size:13px;">
          <i class="bi bi-shield-lock"></i> Roles & Permissions
        </a>
        <a href="/settings/panel" class="list-group-item list-group-item-action d-flex align-items-center gap-3" style="background:transparent; color:var(--text-secondary); border-bottom:1px solid var(--glass-border); padding:14px 20px; transition:all 0.2s; font-size:13px;">
          <i class="bi bi-arrow-repeat"></i> Panel Update
        </a>
        <a href="/settings/audit" class="list-group-item list-group-item-action d-flex align-items-center gap-3" style="background:transparent; color:var(--text-secondary); border:none; padding:14px 20px; transition:all 0.2s; font-size:13px;">
          <i class="bi bi-journal-text"></i> Audit Log
        </a>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-8">
    <div class="lp-glass-card">
      <div class="lp-card-header" style="border-bottom:1px solid var(--glass-border);display:flex;justify-content:space-between;align-items:center;padding-bottom:15px;margin-bottom:15px;">
        <h3 class="lp-card-title m-0">User Management</h3>
        <button class="btn-lp btn-lp-primary btn-lp-sm" onclick="UsersPage.showCreateModal()"><i class="bi bi-person-plus"></i> Add User</button>
      </div>
      <div class="lp-card-body" style="padding:0;overflow-x:auto;">
        <table class="lp-table">
          <thead>
            <tr>
              <th>Username</th>
              <th>Email</th>
              <th>Role</th>
              <th>Status</th>
              <th style="text-align:right">Actions</th>
            </tr>
          </thead>
          <tbody id="usersTableBody">
            <tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:20px;">Loading...</td></tr>
          </tbody>
        </table>
        <div id="usersPagination" style="padding: 0 15px 15px 15px;"></div>
      </div>
    </div>
  </div>
</div>

<!-- Add/Edit User Modal -->
<div class="modal fade" id="userModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content lp-glass-card">
      <div class="modal-header border-0">
        <h5 class="modal-title font-mono" id="userModalTitle" style="font-size:14px">Add User</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="userForm" onsubmit="UsersPage.saveUser(event)">
        <div class="modal-body">
          <input type="hidden" id="userId">
          <div class="lp-form-group">
            <label class="lp-label">Username</label>
            <input type="text" id="username" class="lp-input" required>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Email</label>
            <input type="email" id="email" class="lp-input" required>
          </div>
          <div class="lp-form-group" id="passwordGroup">
            <label class="lp-label">Password</label>
            <input type="password" id="password" class="lp-input">
            <small class="text-muted" style="font-size:11px" id="passwordHelp"></small>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Role</label>
            <select id="role" class="lp-input" required></select>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Status</label>
            <select id="status" class="lp-input">
              <option value="active">Active</option>
              <option value="inactive">Inactive</option>
            </select>
          </div>
        </div>
        <div class="modal-footer border-0">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/settings/users.js"></script>
