      <div class="settings-section-header">
        <h5 class="settings-section-title">
          <i class="bi bi-file-earmark-text text-primary"></i> Version Changelog
        </h5>
        <span class="lp-badge lp-badge-success" style="font-size: 10px;">v1.9.0 Active</span>
