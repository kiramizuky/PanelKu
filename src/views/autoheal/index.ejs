<style>
  .ah-tab {
    padding: 10px 20px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .ah-tab:hover { color: var(--text-primary); background: rgba(255,255,255,0.03); }
  .ah-tab.active { color: var(--accent-primary); background: rgba(99,102,241,0.08); border-bottom-color: var(--accent-primary); }
  .ah-tab-content { display: none; }
  .ah-tab-content.active { display: block; animation: fadeIn 0.25s ease-out; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">
      <i class="bi bi-heart-pulse-fill text-danger me-2"></i> Service Mesh &amp; Auto-Healing
    </h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">
      Service health monitoring, automatic failure recovery, and incident tracking
    </p>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;">
    <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="AutoHealPage.refresh()"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
    <button class="btn-lp btn-lp-warning btn-lp-sm" onclick="AutoHealPage.runCheck()"><i class="bi bi-play-fill"></i> Run Check Now</button>
  </div>
</div>

<!-- Status Summary -->
<div class="row g-3 mb-4">
  <div class="col-3 col-md-3">
    <div class="lp-glass-card p-3 text-center" style="border-left:3px solid var(--accent-success);">
      <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;">Healthy</div>
      <div id="ahHealthyCount" style="font-size:22px;font-weight:700;color:#10b981;">—</div>
    </div>
  </div>
  <div class="col-3 col-md-3">
    <div class="lp-glass-card p-3 text-center" style="border-left:3px solid var(--accent-warning);">
      <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;">Warning</div>
      <div id="ahWarningCount" style="font-size:22px;font-weight:700;color:#f59e0b;">—</div>
    </div>
  </div>
  <div class="col-3 col-md-3">
    <div class="lp-glass-card p-3 text-center" style="border-left:3px solid var(--accent-danger);">
      <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;">Critical</div>
      <div id="ahCriticalCount" style="font-size:22px;font-weight:700;color:#ef4444;">—</div>
    </div>
  </div>
  <div class="col-3 col-md-3">
    <div class="lp-glass-card p-3 text-center" style="border-left:3px solid var(--accent-info);">
      <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;">Engine</div>
      <div id="ahEngineStatus" style="font-size:22px;font-weight:700;color:var(--text-primary);">—</div>
    </div>
  </div>
</div>

<!-- Tabs -->
<div class="lp-glass-card mb-4" style="padding:0;overflow:hidden;">
  <div style="display:flex;border-bottom:1px solid var(--glass-border);overflow-x:auto;background:rgba(0,0,0,0.1);">
    <button class="ah-tab active" data-tab="dashboard" onclick="AutoHealPage.switchTab('dashboard')">
      <i class="bi bi-speedometer2 me-1"></i> Dashboard
    </button>
    <button class="ah-tab" data-tab="config" onclick="AutoHealPage.switchTab('config')">
      <i class="bi bi-sliders me-1"></i> Configuration
    </button>
    <button class="ah-tab" data-tab="services" onclick="AutoHealPage.switchTab('services')">
      <i class="bi bi-hdd-rack me-1"></i> Service Manager
    </button>
    <button class="ah-tab" data-tab="incidents" onclick="AutoHealPage.switchTab('incidents')">
      <i class="bi bi-journal-text me-1"></i> Incidents
    </button>
  </div>

  <!-- ════════════ Tab: Dashboard ════════════ -->
  <div id="tab-dashboard" class="ah-tab-content active" style="padding:20px;">
    <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:12px;">
      <i class="bi bi-hdd-network me-1"></i> Service Health Overview
    </h6>
    <div id="ahServiceGrid" class="row g-2"></div>
  </div>

  <!-- ════════════ Tab: Configuration ════════════ -->
  <div id="tab-config" class="ah-tab-content" style="padding:20px;">
    <div class="row g-4">
      <div class="col-12 col-md-6">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:15px;">
            <i class="bi bi-gear me-1"></i> Engine Settings
          </h6>
          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" id="ahEnabled" onchange="AutoHealPage.toggleEngine()">
            <label class="form-check-label text-white" for="ahEnabled" style="margin-left:8px;">Enable Auto-Healing Engine</label>
          </div>
          <div class="lp-form-group mb-2">
            <label class="lp-label">Check Interval (seconds)</label>
            <input type="number" id="ahInterval" class="lp-input" min="30" max="3600" value="180">
          </div>
          <div class="lp-form-group mb-2">
            <label class="lp-label">Max Restart Attempts</label>
            <input type="number" id="ahMaxRetries" class="lp-input" min="1" max="20" value="3">
          </div>
          <div class="lp-form-group mb-2">
            <label class="lp-label">Cooldown (minutes after max retries)</label>
            <input type="number" id="ahCooldown" class="lp-input" min="1" max="120" value="15">
          </div>
          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="ahNotifyHeal">
            <label class="form-check-label text-white" for="ahNotifyHeal" style="margin-left:8px;font-size:12px;">Notify on healing actions</label>
          </div>
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="ahNotifyRecovery">
            <label class="form-check-label text-white" for="ahNotifyRecovery" style="margin-left:8px;font-size:12px;">Notify on recovery</label>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:15px;">
            <i class="bi bi-shield-exclamation me-1"></i> Alert Thresholds
          </h6>
          <div class="lp-form-group mb-2">
            <label class="lp-label">CPU Threshold (%)</label>
            <input type="number" id="ahCpuThreshold" class="lp-input" min="50" max="100" value="90">
          </div>
          <div class="lp-form-group mb-2">
            <label class="lp-label">Memory Threshold (%)</label>
            <input type="number" id="ahMemThreshold" class="lp-input" min="50" max="100" value="90">
          </div>
          <div class="lp-form-group mb-2">
            <label class="lp-label">Disk Threshold (%)</label>
            <input type="number" id="ahDiskThreshold" class="lp-input" min="50" max="100" value="90">
          </div>
          <hr style="border-color:var(--glass-border);">
          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="ahCheckDocker">
            <label class="form-check-label text-white" for="ahCheckDocker" style="margin-left:8px;font-size:12px;">Monitor Docker Daemon</label>
          </div>
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" id="ahCheckWebsites">
            <label class="form-check-label text-white" for="ahCheckWebsites" style="margin-left:8px;font-size:12px;">Monitor Websites Health</label>
          </div>
          <div style="margin-top:15px;">
            <button class="btn-lp btn-lp-primary w-100" onclick="AutoHealPage.saveConfig()">
              <i class="bi bi-floppy me-1"></i> Save Configuration
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ════════════ Tab: Service Manager ════════════ -->
  <div id="tab-services" class="ah-tab-content" style="padding:20px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin:0;">
        <i class="bi bi-list-check me-1"></i> Monitored Services
      </h6>
    </div>
    <div id="ahServiceManagerList" style="font-size:13px;">
      <div style="padding:20px;text-align:center;color:var(--text-muted);">Loading...</div>
    </div>
  </div>

  <!-- ════════════ Tab: Incidents ════════════ -->
  <div id="tab-incidents" class="ah-tab-content" style="padding:20px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin:0;">
        <i class="bi bi-clock-history me-1"></i> Incident History
      </h6>
      <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="AutoHealPage.loadIncidents()"><i class="bi bi-arrow-clockwise"></i></button>
    </div>
    <div id="ahIncidentList" style="font-size:13px;">
      <div style="padding:20px;text-align:center;color:var(--text-muted);">Loading...</div>
    </div>
  </div>
</div>

<script src="/js/autoheal.js"></script>
