<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">Scheduled Tasks (Cron)</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Manage background automated tasks</p>
  </div>
  <div style="display:flex;gap:10px">
    <button class="btn-lp btn-lp-primary" onclick="CronPage.showCreateModal()"><i class="bi bi-clock-history"></i> Add Cron Job</button>
  </div>
</div>

<div class="lp-glass-card" style="padding:0;overflow-x:auto;">
  <table class="lp-table">
    <thead>
      <tr>
        <th>Task Name</th>
        <th>Schedule</th>
        <th>Command</th>
        <th>Last Run</th>
        <th>Status</th>
        <th style="text-align:right">Actions</th>
      </tr>
    </thead>
    <tbody id="cronTableBody">
      <tr><td colspan="6" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
    </tbody>
  </table>
  <div id="cronPagination" style="padding: 0 15px 15px 15px;"></div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createCronModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px">Add Cron Job</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="createCronForm" onsubmit="CronPage.createTask(event)">
        <div class="modal-body">
          <div class="lp-form-group">
            <label class="lp-label">Task Name</label>
            <input type="text" id="cronName" class="lp-input" placeholder="e.g. Daily Backup" required>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Tipe Cron</label>
            <select id="cronType" class="lp-input" onchange="CronPage.toggleCronType()">
              <option value="tiap_jam">Tiap Jam (Every Hour)</option>
              <option value="n_jam">Setiap N Jam</option>
              <option value="harian" selected>Harian (Tiap Hari)</option>
              <option value="n_hari">Setiap N Hari</option>
              <option value="n_bulan">Tiap Bulan (Tanggal N & Interval B Bulan)</option>
              <option value="mingguan">Mingguan</option>
              <option value="bulanan">Bulanan (Tiap Tanggal N)</option>
              <option value="tanggal">Bulan & Tanggal Tertentu</option>
              <option value="manual">Kustom (Manual)</option>
            </select>
          </div>
          
          <!-- Dynamic Cron Inputs -->
          <div id="cronInputs">
            <!-- N Jam -->
            <div id="cronNjam" class="lp-form-group cron-opt">
              <label class="lp-label">Berapa Jam Sekali (1-23)</label>
              <input type="number" id="inpNjam" class="lp-input" min="1" max="23" value="1">
            </div>

            <!-- Time Selection (used by many) -->
            <div id="cronTime" class="lp-form-group cron-opt" style="display:none;">
              <label class="lp-label">Waktu Eksekusi (Jam:Menit)</label>
              <input type="time" id="inpTime" class="lp-input" value="00:00">
            </div>

            <!-- N Hari -->
            <div id="cronNhari" class="lp-form-group cron-opt" style="display:none;">
              <label class="lp-label">Berapa Hari Sekali</label>
              <input type="number" id="inpNhari" class="lp-input" min="1" max="31" value="2">
            </div>

            <!-- Mingguan -->
            <div id="cronMingguan" class="lp-form-group cron-opt" style="display:none;">
              <label class="lp-label">Hari dalam Seminggu</label>
              <select id="inpMingguan" class="lp-input">
                <option value="1">Senin</option>
                <option value="2">Selasa</option>
                <option value="3">Rabu</option>
                <option value="4">Kamis</option>
                <option value="5">Jumat</option>
                <option value="6">Sabtu</option>
                <option value="0">Minggu</option>
              </select>
            </div>

            <!-- Bulanan / Tanggal -->
            <div id="cronTanggal" class="lp-form-group cron-opt" style="display:none;">
              <label class="lp-label">Tanggal (1-31)</label>
              <input type="number" id="inpTanggal" class="lp-input" min="1" max="31" value="1">
            </div>

            <!-- Interval Bulan -->
            <div id="cronNbulan" class="lp-form-group cron-opt" style="display:none;">
              <label class="lp-label">Interval Bulan (Berapa Bulan Sekali)</label>
              <input type="number" id="inpBulanInterval" class="lp-input" min="1" max="12" value="1" placeholder="1 = Tiap Bulan, 2 = 2 Bulan Sekali">
            </div>

            <!-- Bulan (for Tanggal Tertentu) -->
            <div id="cronBulan" class="lp-form-group cron-opt" style="display:none;">
              <label class="lp-label">Bulan</label>
              <select id="inpBulan" class="lp-input">
                <option value="1">Januari</option>
                <option value="2">Februari</option>
                <option value="3">Maret</option>
                <option value="4">April</option>
                <option value="5">Mei</option>
                <option value="6">Juni</option>
                <option value="7">Juli</option>
                <option value="8">Agustus</option>
                <option value="9">September</option>
                <option value="10">Oktober</option>
                <option value="11">November</option>
                <option value="12">Desember</option>
              </select>
            </div>

            <!-- Manual -->
            <div id="cronManual" class="lp-form-group cron-opt" style="display:none;">
              <label class="lp-label">Cron Expression</label>
              <input type="text" id="cronSchedule" class="lp-input font-mono" placeholder="0 0 * * *">
              <small class="text-muted" style="font-size:11px; margin-top:4px; display:block;">Format: minute hour day month day-of-week</small>
            </div>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Command script</label>
            <input type="text" id="cronCommand" class="lp-input font-mono" placeholder="/path/to/script.sh" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary">Add Task</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/cron.js"></script>
