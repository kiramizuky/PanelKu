<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">Databases</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Manage MySQL, PostgreSQL, and SQLite</p>
  </div>
  <div style="display:flex;gap:10px">
    <button class="btn-lp btn-lp-primary" onclick="DatabasePage.showCreateModal()"><i class="bi bi-plus-lg"></i> Create DB</button>
  </div>
</div>

<style>
  .db-tabs { border-bottom: 1px solid var(--glass-border); }
  .db-tabs .nav-link { color: var(--text-muted); background: transparent; border: none; padding: 10px 16px; font-weight: 500; border-radius: 8px 8px 0 0; }
  .db-tabs .nav-link:hover { color: var(--text-primary); border-color: transparent; }
  .db-tabs .nav-link.active { 
    color: var(--accent-primary); 
    background: rgba(99,102,241,0.1); 
    border: 1px solid var(--glass-border); 
    border-bottom-color: transparent; 
  }
</style>

<ul class="nav nav-tabs mb-4 db-tabs">
  <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#mysql">MySQL</a></li>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#postgres">PostgreSQL</a></li>
  <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#sqlite">SQLite</a></li>
</ul>

<div class="tab-content">
  <!-- MySQL Tab -->
  <div class="tab-pane fade show active" id="mysql">
    <div class="lp-glass-card" style="padding:0;overflow-x:auto;">
      <table class="lp-table">
        <thead>
          <tr>
            <th>Database Name</th>
            <th style="text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="mysqlTableBody">
          <tr><td colspan="2" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
        </tbody>
      </table>
      <div id="mysqlPagination" style="padding: 0 15px 15px 15px;"></div>
    </div>
  </div>

  <!-- PostgreSQL Tab -->
  <div class="tab-pane fade" id="postgres">
    <div class="lp-glass-card" style="padding:0;overflow-x:auto;">
      <table class="lp-table">
        <thead>
          <tr>
            <th>Database Name</th>
            <th style="text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="postgresTableBody">
          <tr><td colspan="2" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
        </tbody>
      </table>
      <div id="postgresPagination" style="padding: 0 15px 15px 15px;"></div>
    </div>
  </div>


  <!-- SQLite Tab -->
  <div class="tab-pane fade" id="sqlite">
    <div class="lp-glass-card" style="padding:0;overflow-x:auto;">
      <table class="lp-table">
        <thead>
          <tr>
            <th>Database File</th>
            <th style="text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="sqliteTableBody">
          <tr><td colspan="2" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
        </tbody>
      </table>
      <div id="sqlitePagination" style="padding: 0 15px 15px 15px;"></div>
    </div>
  </div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createDbModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px">Create Database</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="createDbForm" onsubmit="DatabasePage.createDatabase(event)">
        <div class="modal-body">
          <div class="lp-form-group">
            <label class="lp-label">Type</label>
            <select id="dbType" class="lp-input" required>
              <option value="mysql">MySQL</option>
              <option value="postgres">PostgreSQL</option>
              <option value="sqlite">SQLite</option>
            </select>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Database Name</label>
            <input type="text" id="dbName" class="lp-input" placeholder="my_database" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary">Create Database</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Install Password Config Modal -->
<div class="modal fade" id="installConfigModal" tabindex="-1" data-bs-backdrop="static">
  <div class="modal-dialog">
    <div class="modal-content" style="background:var(--bg-primary); border:1px solid var(--glass-border);">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px" id="installConfigTitle">Configure Database</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="installConfigForm" onsubmit="DatabasePage.submitInstall(event)">
        <input type="hidden" id="installPkgName">
        <div class="modal-body">
          <p id="installConfigDescription" class="text-muted" style="font-size:13px; margin-bottom:15px;"></p>
          <div class="lp-form-group">
            <label class="lp-label" id="installPasswordLabel">Root Password</label>
            <input type="password" id="installPassword" class="lp-input" placeholder="Enter secure password" required minlength="4">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary">Install & Configure</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Database Explorer Modal -->
<div class="modal fade" id="exploreDbModal" tabindex="-1">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content" style="background:#0b0f19; border:1px solid var(--glass-border); color:#fff;">
      <div class="modal-header" style="border-bottom:1px solid var(--glass-border);">
        <h5 class="modal-title font-mono" style="font-size:14px" id="exploreDbTitle">Database Explorer</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="padding:0; display:flex; height:600px; overflow:hidden;">
        <!-- Left Sidebar: Tables List -->
        <div style="width:220px; background:#070a13; border-right:1px solid rgba(255,255,255,0.05); overflow-y:auto; padding:15px;">
          <h6 style="font-size:11px; font-weight:700; text-transform:uppercase; color:var(--text-muted); margin-bottom:10px; letter-spacing:0.5px;">Tables</h6>
          <div id="dbExplorerTablesList" style="display:flex; flex-direction:column; gap:5px;">
            <p class="text-muted" style="font-size:12px;">No tables found</p>
          </div>
        </div>
        <!-- Right Area: Query Console & Results -->
        <div style="flex:1; display:flex; flex-direction:column; overflow:hidden;">
          <!-- SQL Input -->
          <div style="padding:15px; border-bottom:1px solid rgba(255,255,255,0.05); background:rgba(0,0,0,0.15);">
            <label class="lp-label" style="font-size:11px;">SQL Query Console</label>
            <textarea id="dbQueryInput" class="lp-input font-mono" rows="4" style="font-size:12.5px; resize:none;" placeholder="SELECT * FROM table_name LIMIT 10;"></textarea>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-top:10px;">
              <span id="dbQueryStatus" style="font-size:11px; color:var(--text-muted);">Ready</span>
              <button class="btn-lp btn-lp-primary btn-lp-sm" onclick="DatabasePage.runExplorerQuery()"><i class="bi bi-play-fill"></i> Run Query</button>
            </div>
          </div>
          <!-- Results Table -->
          <div style="flex:1; overflow:auto; padding:15px; background:#0a0e1a;">
            <table class="lp-table" style="font-size:12px; margin:0;" id="dbExplorerResultsTable">
              <thead id="dbExplorerResultsHead">
                <tr><th>Query results will be displayed here</th></tr>
              </thead>
              <tbody id="dbExplorerResultsBody">
                <tr><td class="text-muted">Execute a query or select a table to begin.</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/js/database.js"></script>
