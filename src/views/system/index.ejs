<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">System</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Manage host services and updates</p>
  </div>
</div>

<div class="row g-4">
  <div class="col-12 col-md-8">
    <div class="lp-glass-card" style="padding:0;overflow-x:auto;">
      <div class="lp-card-title" style="padding: 20px 20px 0;">Host Services</div>
      <table class="lp-table">
        <thead>
          <tr>
            <th>Service Name</th>
            <th>Status</th>
            <th style="text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="servicesTableBody">
          <tr><td colspan="3" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
        </tbody>
      </table>
    </div>

    <!-- SSH Key Manager & config -->
    <div class="lp-glass-card mt-4" style="padding:25px; border-radius:16px;">
      <div style="border-bottom:1px solid var(--glass-border); padding-bottom:12px; margin-bottom:20px; display:flex; justify-content:space-between; align-items:center;">
        <h5 style="font-weight:700; margin:0; color:var(--text-primary);"><i class="bi bi-key me-2 text-warning"></i>SSH Key Manager</h5>
        <button class="btn-lp btn-lp-primary btn-lp-sm" onclick="SystemPage.showAddSshKeyModal()" style="font-size:11px; padding:6px 12px;"><i class="bi bi-plus-lg"></i> Add SSH Key</button>
      </div>

      <div class="row g-4">
        <!-- Config: Port & Password Authentication -->
        <div class="col-12 col-md-4" style="border-right: 1px solid var(--glass-border); padding-right: 20px;">
          <h6 style="font-size:13px; font-weight:600; color:var(--text-primary); margin-bottom:15px;">SSH Daemon Config</h6>
          <div class="mb-3">
            <label class="lp-label" style="font-size:11px;">SSH Port</label>
            <input type="number" id="sshPort" class="lp-input" placeholder="22" style="height:34px;">
          </div>
          <div style="display:flex; align-items:center; justify-content:space-between; padding:10px; background:rgba(0,0,0,0.15); border-radius:8px; border: 1px solid var(--glass-border); margin-bottom:15px;">
            <span style="font-size:12px; font-weight:500;">Password Login</span>
            <div class="form-check form-switch" style="margin:0;">
              <input class="form-check-input" type="checkbox" id="sshPasswordAuth" style="cursor:pointer;">
            </div>
          </div>
          <button class="btn-lp btn-lp-primary w-100" onclick="SystemPage.saveSshConfig()" style="font-size:12px; height:34px; padding:0;">Save Config & Restart</button>
        </div>

        <!-- Keys list -->
        <div class="col-12 col-md-8" style="padding-left: 20px;">
          <h6 style="font-size:13px; font-weight:600; color:var(--text-primary); margin-bottom:15px;">Authorized SSH Keys</h6>
          <div style="max-height: 200px; overflow-y: auto;">
            <table class="w-100 text-left text-xs" style="color: var(--text-secondary);">
              <thead>
                <tr style="border-bottom: 1px solid var(--glass-border); font-weight:600; color: var(--text-muted); height: 28px;">
                  <th style="padding-bottom:8px; width:25%;">Type</th>
                  <th style="padding-bottom:8px; width:60%;">Comment / Name</th>
                  <th style="padding-bottom:8px; width:15%; text-align:right;">Action</th>
                </tr>
              </thead>
              <tbody id="sshKeysTableBody">
                <tr><td colspan="3" style="text-align:center; padding:15px; color:var(--text-muted);">Loading SSH Keys...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-12 col-md-4">
    <div class="lp-glass-card mb-4" style="height:300px">
      <div class="lp-card-title" id="pmTitle">Package Manager</div>
      <p style="color:var(--text-muted);font-size:13px;">Update the system package repository and install available upgrades.</p>
      
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:15px;padding:10px;background:rgba(255,255,255,0.05);border-radius:8px;">
        <span style="font-size:13px;font-weight:500;">Auto-Update System</span>
        <div class="form-check form-switch" style="margin:0;">
          <input class="form-check-input" type="checkbox" id="autoUpdateToggle" onchange="SystemPage.toggleAutoUpdate()" style="cursor:pointer;">
        </div>
      </div>

      <button class="btn-lp btn-lp-primary w-100 mb-2" id="btnUpdate" onclick="SystemPage.runPM('update')">
        <i class="bi bi-arrow-repeat"></i> Run Update
      </button>
      <button class="btn-lp btn-lp-primary w-100" id="btnUpgrade" onclick="SystemPage.runPM('upgrade')" style="background:var(--accent-info);">
        <i class="bi bi-download"></i> Run Upgrade
      </button>
    </div>

    <div class="lp-glass-card d-flex flex-column justify-content-between" style="height:300px">
      <div>
        <div class="lp-card-title">Power & Maintenance</div>
        <p style="color:var(--text-muted);font-size:13px;">Manage server power state or restart the panel application.</p>
      </div>
      <div>
        <button class="btn-lp w-100 mb-2" onclick="SystemPage.restartPanel()" style="background:rgba(56, 189, 248, 0.2);color:#38bdf8;border:1px solid rgba(56, 189, 248, 0.3);border-radius:10px;padding:10px;font-weight:600;">
          <i class="bi bi-arrow-clockwise"></i> Restart Panel
        </button>
        <button class="btn-lp w-100" onclick="SystemPage.reboot()" style="background:var(--accent-danger);color:white;border-radius:10px;padding:10px;font-weight:600;">
          <i class="bi bi-power"></i> Reboot Server
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal for Package Manager Logs -->
<div class="modal fade" id="aptLogModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px" id="pmLogModalTitle">Package Manager Log</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <pre id="aptLogContent" style="background:#0a0a0a;color:#a3e635;padding:15px;border-radius:8px;font-size:12px;max-height:400px;overflow-y:auto;"></pre>
      </div>
    </div>
  </div>
</div>

<!-- Modal for Add SSH Key -->
<div class="modal fade" id="addSshKeyModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border: 1px solid rgba(255,255,255,0.1); background: rgba(20,20,25,0.95);">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);">
        <h5 class="modal-title font-mono text-white" style="font-size:15px;">Add Public SSH Key</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="lp-label" style="display:block; margin-bottom:6px; font-size:12px;">Paste Public Key (id_rsa.pub)</label>
          <textarea id="sshPublicKeyInput" class="form-control lp-input w-100" rows="5" placeholder="e.g. ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAACAQD... user@host" style="background: rgba(0,0,0,0.2); font-family: monospace; font-size:11px; color: var(--text-primary); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 10px;"></textarea>
        </div>
      </div>
      <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);">
        <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-lp btn-lp-primary" onclick="SystemPage.addSshKey()">Add Key</button>
      </div>
    </div>
  </div>
</div>

<script src="/js/system.js"></script>
