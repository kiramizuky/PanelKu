<div class="lp-page-header">
  <div>
    <h1 class="lp-page-title">System</h1>
    <p class="lp-page-subtitle">Manage host services and updates</p>
  </div>
</div>

<div class="row g-4 align-items-start">
  <div class="col-12 col-md-8">
    <!-- Host Services Table -->
    <div class="lp-glass-card system-services-card">
      <div class="lp-card-title">Host Services</div>
      <div class="system-services-scroll">
        <table class="lp-table">
          <thead>
            <tr>
              <th>Service Name</th>
              <th>Status</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody id="servicesTableBody">
            <tr><td colspan="3" class="text-center text-muted py-4">Loading...</td></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- SSH Key Manager -->
    <div class="lp-glass-card system-ssh-card">
      <div class="system-card-header">
        <h5 class="system-card-title"><i class="bi bi-key me-2 text-warning"></i>SSH Key Manager</h5>
        <button class="btn-lp btn-lp-primary btn-lp-sm" onclick="SystemPage.showAddSshKeyModal()"><i class="bi bi-plus-lg"></i> Add SSH Key</button>
      </div>

      <div class="system-ssh-grid">
        <!-- SSH Config -->
        <div class="system-ssh-config">
          <h6 class="system-section-title">SSH Daemon Config</h6>
          <div class="mb-3">
            <label class="lp-label">SSH Port</label>
            <input type="number" id="sshPort" class="lp-input" placeholder="22">
          </div>
          <div class="system-toggle-row">
            <span>Password Login</span>
            <div class="form-check form-switch m-0">
              <input class="form-check-input" type="checkbox" id="sshPasswordAuth">
            </div>
          </div>
          <button class="btn-lp btn-lp-primary w-100" onclick="SystemPage.saveSshConfig()">Save Config & Restart</button>
        </div>

        <!-- SSH Keys List -->
        <div class="system-ssh-keys">
          <h6 class="system-section-title">Authorized SSH Keys</h6>
          <div class="system-ssh-keys-scroll">
            <table class="system-keys-table">
              <thead>
                <tr>
                  <th style="width:25%;">Type</th>
                  <th style="width:60%;">Comment / Name</th>
                  <th style="width:15%;" class="text-end">Action</th>
                </tr>
              </thead>
              <tbody id="sshKeysTableBody">
                <tr><td colspan="3" class="text-center text-muted py-3">Loading SSH Keys...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- PHP-FPM Pool Manager -->
    <div class="lp-glass-card system-php-card">
      <div class="system-card-header">
        <h5 class="system-card-title"><i class="bi bi-gear-wide-connected me-2 text-primary"></i>PHP-FPM Pool Manager</h5>
      </div>
      <div class="row g-3">
        <div class="col-6 col-md-3">
          <label class="lp-label">pm.max_children</label>
          <input type="number" id="phpMaxChildren" class="lp-input">
        </div>
        <div class="col-6 col-md-3">
          <label class="lp-label">pm.start_servers</label>
          <input type="number" id="phpStartServers" class="lp-input">
        </div>
        <div class="col-6 col-md-3">
          <label class="lp-label">pm.min_spare_servers</label>
          <input type="number" id="phpMinSpare" class="lp-input">
        </div>
        <div class="col-6 col-md-3">
          <label class="lp-label">pm.max_spare_servers</label>
          <input type="number" id="phpMaxSpare" class="lp-input">
        </div>
      </div>
      <button class="btn-lp btn-lp-primary mt-3 w-100" onclick="SystemPage.savePHPConfig()">Save PHP-FPM Config & Reload</button>
    </div>
  </div>

  <div class="col-12 col-md-4 system-sidebar">
    <!-- Package Manager -->
    <div class="lp-glass-card system-pm-card">
      <div class="lp-card-title" id="pmTitle">Package Manager</div>
      <p class="system-card-desc">Update the system package repository and install available upgrades.</p>

      <div class="system-toggle-row mb-3">
        <span>Auto-Update System</span>
        <div class="form-check form-switch m-0">
          <input class="form-check-input" type="checkbox" id="autoUpdateToggle" onchange="SystemPage.toggleAutoUpdate()">
        </div>
      </div>

      <button class="btn-lp btn-lp-primary w-100 mb-2" id="btnUpdate" onclick="SystemPage.runPM('update')">
        <i class="bi bi-arrow-repeat"></i> Run Update
      </button>
      <button class="btn-lp w-100" id="btnUpgrade" onclick="SystemPage.runPM('upgrade')" style="background:var(--accent-info);color:#fff;">
        <i class="bi bi-download"></i> Run Upgrade
      </button>
    </div>

    <!-- Power & Maintenance -->
    <div class="lp-glass-card system-power-card">
      <div>
        <div class="lp-card-title">Power & Maintenance</div>
        <p class="system-card-desc">Manage server power state or restart the panel application.</p>
      </div>
      <div class="system-power-actions">
        <button class="btn-lp system-btn-restart" onclick="SystemPage.restartPanel()">
          <i class="bi bi-arrow-clockwise"></i> Restart Panel
        </button>
        <button class="btn-lp system-btn-reboot" onclick="SystemPage.reboot()">
          <i class="bi bi-power"></i> Reboot Server
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Modal for Package Manager Logs -->
<div class="modal fade" id="aptLogModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px" id="pmLogModalTitle">Package Manager Log</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <pre id="aptLogContent" style="background:#0a0a0a;color:#a3e635;padding:15px;border-radius:8px;font-size:12px;max-height:400px;overflow-y:auto;"></pre>
      </div>
    </div>
  </div>
</div>

<!-- Modal for Add SSH Key -->
<div class="modal fade" id="addSshKeyModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border: 1px solid rgba(255,255,255,0.1); background: rgba(20,20,25,0.95);">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);">
        <h5 class="modal-title font-mono text-white" style="font-size:15px;">Add Public SSH Key</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="lp-label" style="display:block; margin-bottom:6px; font-size:12px;">Paste Public Key (id_rsa.pub)</label>
          <textarea id="sshPublicKeyInput" class="form-control lp-input w-100" rows="5" placeholder="e.g. ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAACAQD... user@host" style="background: rgba(0,0,0,0.2); font-family: monospace; font-size:11px; color: var(--text-primary); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; padding: 10px;"></textarea>
        </div>
      </div>
      <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);">
        <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-lp btn-lp-primary" onclick="SystemPage.addSshKey()">Add Key</button>
      </div>
    </div>
  </div>
</div>

<script src="/js/system.js"></script>
