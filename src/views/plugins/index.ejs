<style>
  .pl-tab {
    padding: 10px 20px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .pl-tab:hover { color: var(--text-primary); background: rgba(255,255,255,0.03); }
  .pl-tab.active { color: var(--accent-primary); background: rgba(99,102,241,0.08); border-bottom-color: var(--accent-primary); }
  .pl-tab-content { display: none; }
  .pl-tab-content.active { display: block; animation: fadeIn 0.25s ease-out; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
</style>

<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;"><i class="bi bi-plugin text-info me-2"></i> Plugins & Marketplace</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Extend your panel with plugins and custom themes</p>
  </div>
</div>

<div class="lp-glass-card mb-4" style="padding:0;overflow:hidden;">
  <div style="display:flex;border-bottom:1px solid var(--glass-border);overflow-x:auto;background:rgba(0,0,0,0.1);">
    <button class="pl-tab active" data-tab="installed" onclick="PluginsPage.switchTab('installed')">
      <i class="bi bi-box-seam me-1"></i> Installed
    </button>
    <button class="pl-tab" data-tab="marketplace" onclick="PluginsPage.switchTab('marketplace');PluginsPage.loadMarketplace()">
      <i class="bi bi-shop me-1"></i> Marketplace
    </button>
    <button class="pl-tab" data-tab="upload" onclick="PluginsPage.switchTab('upload')">
      <i class="bi bi-upload me-1"></i> Upload
    </button>
  </div>

  <!-- Tab: Installed -->
  <div id="tab-installed" class="pl-tab-content active" style="padding:20px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:8px;">
      <h5 style="font-size:15px;font-weight:600;margin:0;color:var(--text-primary);">
        <i class="bi bi-box-seam text-primary me-1"></i> Installed Plugins
      </h5>
      <input type="text" id="installedFilter" class="lp-input" style="width:200px;font-size:12px;" placeholder="Filter plugins..." oninput="PluginsPage.filterInstalled()">
    </div>
    <div class="row g-3" id="pluginsContainer"></div>
  </div>

  <!-- Tab: Marketplace -->
  <div id="tab-marketplace" class="pl-tab-content" style="padding:20px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:8px;">
      <h5 style="font-size:15px;font-weight:600;margin:0;color:var(--text-primary);">
        <i class="bi bi-shop text-warning me-1"></i> Plugin Marketplace
      </h5>
      <div style="display:flex;gap:8px;">
        <select id="mkCategory" class="lp-input" style="width:140px;font-size:12px;" onchange="PluginsPage.filterMarketplace()">
          <option value="all">All Categories</option>
          <option value="runtime">Runtime</option>
          <option value="security">Security</option>
          <option value="storage">Storage</option>
          <option value="monitoring">Monitoring</option>
          <option value="database">Database</option>
          <option value="network">Network</option>
          <option value="backup">Backup</option>
          <option value="smarthome">Smart Home</option>
        </select>
        <input type="text" id="mkSearch" class="lp-input" style="width:180px;font-size:12px;" placeholder="Search marketplace..." oninput="PluginsPage.filterMarketplace()">
      </div>
    </div>
    <div class="row g-3" id="marketplaceContainer">
      <div class="col-12" style="text-align:center;padding:30px;color:var(--text-muted);">
        <i class="bi bi-arrow-clockwise spin me-2"></i>Loading marketplace...
      </div>
    </div>
  </div>

  <!-- Tab: Upload -->
  <div id="tab-upload" class="pl-tab-content" style="padding:20px;">
    <div class="row g-3">
      <div class="col-12 col-md-6">
        <div class="lp-glass-card" style="background:rgba(0,0,0,0.08);">
          <h5 style="font-size:14px;font-weight:600;margin-bottom:12px;">
            <i class="bi bi-upload text-success me-1"></i> Upload Plugin
          </h5>
          <p style="font-size:12px;color:var(--text-muted);margin-bottom:14px;">
            Upload a plugin zip file. It must contain a valid <code>plugin.json</code> manifest.
          </p>
          <div style="border:2px dashed var(--glass-border);border-radius:10px;padding:24px;text-align:center;">
            <i class="bi bi-file-zip" style="font-size:32px;color:var(--text-muted);display:block;margin-bottom:8px;"></i>
            <p style="font-size:12px;color:var(--text-secondary);margin-bottom:10px;">Select a .zip plugin file</p>
            <button class="btn-lp btn-lp-primary" onclick="PluginsPage.triggerUpload()">
              <i class="bi bi-folder2-open me-1"></i> Browse
            </button>
          </div>
          <input type="file" id="pluginUploadInput" accept=".zip" style="display:none;" onchange="PluginsPage.uploadPlugin(this)">
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="lp-glass-card" style="background:rgba(0,0,0,0.08);">
          <h5 style="font-size:14px;font-weight:600;margin-bottom:12px;">
            <i class="bi bi-info-circle text-info me-1"></i> Plugin SDK
          </h5>
          <p style="font-size:12px;color:var(--text-secondary);line-height:1.6;">
            Each plugin must have this structure:
          </p>
          <pre style="background:rgba(0,0,0,0.15);padding:10px;border-radius:6px;font-family:monospace;font-size:11px;line-height:1.5;color:var(--text-secondary);">
plugin-name/
  plugin.json      # Manifest (required)
  index.js         # Entry point (required)
  package.json     # Dependencies (optional)
  public/          # Static assets (optional)
  views/           # EJS templates (optional)</pre>
          <p style="font-size:12px;color:var(--text-secondary);margin-top:8px;">
            The <code>plugin.json</code> must include: <code>name</code>, <code>version</code>, <code>description</code>, <code>icon</code>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Plugin Config Modal -->
<div class="modal fade" id="pluginConfigModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border:1px solid rgba(255,255,255,0.1);background:rgba(20,20,25,0.95);backdrop-filter:blur(10px);border-radius:12px;">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);padding:15px 20px;">
        <h5 class="modal-title font-mono" id="modalTitle" style="font-size:15px;font-weight:600;color:var(--text-primary);">Configure Plugin</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="padding:20px;">
        <input type="hidden" id="configPluginId">
        <input type="hidden" id="configMode">
        <div class="mb-3">
          <label class="lp-label">Plugin Name</label>
          <input type="text" id="configPluginName" class="form-control lp-input w-100" readonly style="background:rgba(0,0,0,0.2);color:var(--text-muted);border-radius:8px;height:38px;padding:0 12px;font-size:13px;">
        </div>
        <div class="mb-3">
          <label class="lp-label">Proxy Target URL (Optional)</label>
          <input type="url" id="configProxyUrl" class="form-control lp-input w-100" placeholder="e.g. http://192.168.1.100:8080">
          <small style="color:var(--text-muted);font-size:11px;margin-top:6px;display:block;">Leave blank for local plugin. If configured, requests proxy to the target URL.</small>
        </div>
      </div>
      <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);padding:15px 20px;">
        <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-lp btn-lp-primary" onclick="PluginsPage.submitConfig()">Save</button>
      </div>
    </div>
  </div>
</div>

<script>
  const PluginsPage = (() => {
    let bsModal = null;
    let marketplaceData = [];

    // ── Tab Switching ────────────────────────────────────
    function switchTab(tabId) {
      document.querySelectorAll('.pl-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.pl-tab-content').forEach(t => t.classList.remove('active'));
      const btn = document.querySelector(`.pl-tab[data-tab="${tabId}"]`);
      if (btn) btn.classList.add('active');
      const content = document.getElementById(`tab-${tabId}`);
      if (content) content.classList.add('active');
    }

    // ── Installed Plugins ────────────────────────────────
    async function loadInstalled() {
      try {
        const res = await LP.get('/plugins');
        if (res?.success) renderInstalled(res.data || []);
      } catch { LP.toast('Failed to load plugins', 'error'); }
    }

    function renderInstalled(plugins) {
      const container = document.getElementById('pluginsContainer');
      if (!plugins || plugins.length === 0) {
        container.innerHTML = '<div class="col-12"><div style="text-align:center;padding:40px;color:var(--text-muted);"><i class="bi bi-inbox" style="font-size:40px;display:block;margin-bottom:10px;"></i>No plugins installed yet.<br>Check the Marketplace tab to install available plugins.</div></div>';
        return;
      }
      container.innerHTML = plugins.map(p => `
        <div class="col-md-6 col-lg-4">
          <div class="lp-glass-card h-100 d-flex flex-column" style="padding:18px;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:40px;height:40px;border-radius:10px;background:rgba(0,0,0,0.15);display:flex;align-items:center;justify-content:center;">
                  <i class="bi ${p.icon || 'bi-plugin'}" style="color:${p.color || '#38bdf8'};font-size:20px;"></i>
                </div>
                <div>
                  <div style="font-weight:600;font-size:14px;color:var(--text-primary);">${p.name}</div>
                  <div style="font-size:11px;color:var(--text-muted);">v${p.version}</div>
                </div>
              </div>
              ${p.updateAvailable ? '<span class="lp-badge lp-badge-warning" style="font-size:9px;">Update</span>' : ''}
            </div>
            <p style="font-size:12px;color:var(--text-secondary);flex-grow:1;margin-bottom:10px;">${p.description || ''}</p>
            ${p.proxyUrl ? `<div style="font-size:11px;color:#38bdf8;background:rgba(56,189,248,0.08);padding:5px 8px;border-radius:6px;margin-bottom:8px;"><i class="bi bi-link-45deg"></i> ${p.proxyUrl}</div>` : ''}
            <div style="display:flex;gap:6px;margin-top:auto;flex-wrap:wrap;">
              ${p.updateAvailable ? `<button class="btn-lp flex-grow-1 text-center" style="background:var(--accent-warning);color:#fff;font-size:12px;font-weight:600;border-radius:8px;height:34px;padding:0 8px;border:none;" onclick="PluginsPage.update('${p.id}', this)"><i class="bi bi-arrow-up-circle-fill me-1"></i>Update</button>` : ''}
              <a href="${p.path}" target="${p.proxyUrl ? '_blank' : '_self'}" class="btn-lp btn-lp-primary flex-grow-1 text-center" style="text-decoration:none;line-height:34px;height:34px;padding:0 12px;font-size:13px;border-radius:8px;">Open</a>
              <button class="btn-lp btn-lp-ghost" style="width:34px;height:34px;padding:0;border-radius:8px;" onclick="PluginsPage.showConfigModal('${p.id}','${p.name.replace(/'/g,"\\'")}','${p.proxyUrl || ''}','update')" title="Config"><i class="bi bi-gear"></i></button>
              <button class="btn-lp btn-lp-ghost text-danger" style="width:34px;height:34px;padding:0;border-radius:8px;" onclick="PluginsPage.uninstall('${p.id}')" title="Uninstall"><i class="bi bi-trash"></i></button>
            </div>
          </div>
        </div>
      `).join('');
    }

    function filterInstalled() {
      const q = document.getElementById('installedFilter').value.toLowerCase();
      document.querySelectorAll('#pluginsContainer > div').forEach(el => {
        el.style.display = el.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    }

    // ── Marketplace ──────────────────────────────────────
    async function loadMarketplace() {
      const container = document.getElementById('marketplaceContainer');
      container.innerHTML = '<div class="col-12" style="text-align:center;padding:30px;color:var(--text-muted);"><div class="spinner-border spinner-border-sm me-2"></div>Loading marketplace...</div>';
      try {
        const res = await LP.get('/plugins/marketplace');
        if (res?.success) {
          marketplaceData = res.data || [];
          filterMarketplace();
        } else {
          container.innerHTML = '<div class="col-12" style="text-align:center;padding:30px;color:var(--accent-danger);">Failed to load marketplace</div>';
        }
      } catch {
        container.innerHTML = '<div class="col-12" style="text-align:center;padding:30px;color:var(--accent-danger);">Error loading marketplace</div>';
      }
    }

    function filterMarketplace() {
      const cat = document.getElementById('mkCategory').value;
      const q = document.getElementById('mkSearch').value.toLowerCase();
      const filtered = marketplaceData.filter(p => {
        if (cat !== 'all' && p.category !== cat) return false;
        if (q && !p.name.toLowerCase().includes(q) && !p.description.toLowerCase().includes(q)) return false;
        return true;
      });

      const container = document.getElementById('marketplaceContainer');
      if (filtered.length === 0) {
        container.innerHTML = '<div class="col-12" style="text-align:center;padding:30px;color:var(--text-muted);">No matching plugins found</div>';
        return;
      }
      container.innerHTML = filtered.map(p => `
        <div class="col-md-6 col-lg-4">
          <div class="lp-glass-card h-100 d-flex flex-column" style="padding:18px;">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px;">
              <div style="display:flex;align-items:center;gap:10px;">
                <div style="width:40px;height:40px;border-radius:10px;background:rgba(0,0,0,0.15);display:flex;align-items:center;justify-content:center;">
                  <i class="bi ${p.icon || 'bi-plugin'}" style="color:${p.color || '#38bdf8'};font-size:20px;"></i>
                </div>
                <div>
                  <div style="font-weight:600;font-size:14px;color:var(--text-primary);">${p.name}</div>
                  <div style="font-size:11px;color:var(--text-muted);">v${p.version} · ${p.author}</div>
                </div>
              </div>
              <span class="lp-badge lp-badge-ghost" style="font-size:9px;text-transform:uppercase;">${p.category}</span>
            </div>
            <p style="font-size:12px;color:var(--text-secondary);flex-grow:1;margin-bottom:8px;">${p.description}</p>
            <div style="font-size:11px;color:var(--text-muted);margin-bottom:10px;">
              <i class="bi bi-download me-1"></i> ${p.downloads || 0} downloads
            </div>
            <div>
              ${p.installed
                ? '<span class="lp-badge lp-badge-success w-100 text-center" style="padding:8px;"><i class="bi bi-check-circle me-1"></i> Installed</span>'
                : `<button class="btn-lp btn-lp-primary w-100" onclick="PluginsPage.showConfigModal('${p.id}','${p.name.replace(/'/g,"\\'")}','','install')"><i class="bi bi-download me-1"></i> Install</button>`
              }
            </div>
          </div>
        </div>
      `).join('');
    }

    // ── Plugin Upload ────────────────────────────────────
    function triggerUpload() {
      document.getElementById('pluginUploadInput').click();
    }

    async function uploadPlugin(input) {
      const file = input.files[0];
      if (!file) return;
      LP.toast('Plugin upload feature requires server-side processing. For now, extract the zip to /opt/panelku/plugins/ and refresh.', 'info');
      input.value = '';
    }

    // ── Config Modal ─────────────────────────────────────
    function showConfigModal(id, name, proxyUrl, mode) {
      document.getElementById('configPluginId').value = id;
      document.getElementById('configMode').value = mode;
      document.getElementById('configPluginName').value = name;
      document.getElementById('configProxyUrl').value = proxyUrl || '';
      document.getElementById('modalTitle').textContent = mode === 'install' ? `Install ${name}` : `Configure ${name}`;
      if (!bsModal) bsModal = new bootstrap.Modal(document.getElementById('pluginConfigModal'));
      bsModal.show();
    }

    async function submitConfig() {
      const id = document.getElementById('configPluginId').value;
      const mode = document.getElementById('configMode').value;
      const proxyUrl = document.getElementById('configProxyUrl').value;
      try {
        const endpoint = mode === 'install' ? '/plugins/install' : '/plugins/proxy';
        const res = await LP.post(endpoint, { id, proxyUrl });
        if (res?.success) {
          LP.toast(res.message, 'success');
          if (bsModal) bsModal.hide();
          loadInstalled();
          if (marketplaceData.length > 0) loadMarketplace();
        } else {
          LP.toast(res?.message || 'Action failed', 'error');
        }
      } catch { LP.toast('Error submitting configuration', 'error'); }
    }

    async function uninstall(id) {
      try {
        const res = await LP.post('/plugins/uninstall', { id });
        if (res?.success) { LP.toast(res.message, 'success'); loadInstalled(); }
        else LP.toast(res?.message || 'Failed to uninstall', 'error');
      } catch { LP.toast('Uninstallation error', 'error'); }
    }

    async function update(id, btn) {
      const orig = btn.innerHTML;
      btn.innerHTML = '<i class="bi bi-arrow-clockwise spin"></i> Updating...';
      btn.disabled = true;
      try {
        const res = await LP.post('/plugins/update', { id });
        if (res?.success) { LP.toast(res.message, 'success'); loadInstalled(); }
        else LP.toast(res?.message || 'Update failed', 'error');
      } catch { LP.toast('Update error', 'error'); }
      finally { btn.innerHTML = orig; btn.disabled = false; }
    }

    document.addEventListener('DOMContentLoaded', loadInstalled);

    return { switchTab, loadMarketplace, filterMarketplace, filterInstalled, triggerUpload, uploadPlugin, showConfigModal, submitConfig, uninstall, update };
  })();
</script>
