<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">Plugins & Marketplace</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Extend your panel functionality</p>
  </div>
</div>

<div class="row" id="pluginsContainer">
  <!-- Rendered via JS -->
</div>

<!-- Plugin Config Modal -->
<div class="modal fade" id="pluginConfigModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border: 1px solid rgba(255,255,255,0.1); background: rgba(20,20,25,0.95); backdrop-filter: blur(10px); border-radius: 12px;">
      <div class="modal-header" style="border-bottom: 1px solid rgba(255,255,255,0.1); padding: 15px 20px;">
        <h5 class="modal-title font-mono" id="modalTitle" style="font-size:15px; font-weight:600; color:var(--text-primary);">Configure Plugin</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding: 20px;">
        <input type="hidden" id="configPluginId">
        <input type="hidden" id="configMode">
        <div class="mb-3">
          <label class="lp-label" style="font-size:12px; font-weight:500; color:var(--text-muted); margin-bottom:6px; display:block;">Plugin Name</label>
          <input type="text" id="configPluginName" class="form-control lp-input w-100" readonly style="background: rgba(0,0,0,0.2); color: var(--text-muted); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; height: 38px; padding: 0 12px; font-size: 13px;">
        </div>
        <div class="mb-3">
          <label class="lp-label" style="font-size:12px; font-weight:500; color:var(--text-primary); margin-bottom:6px; display:block;">Proxy Target URL (Optional)</label>
          <input type="url" id="configProxyUrl" class="form-control lp-input w-100" placeholder="e.g. http://192.168.1.100:8080" style="background: rgba(255,255,255,0.05); color: var(--text-primary); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; height: 38px; padding: 0 12px; font-size: 13px;">
          <small style="color: var(--text-muted); font-size:11px; margin-top:6px; display:block; line-height: 1.4;">Leave blank to run the plugin locally on the panel. If configured, requests to this plugin will be proxied to the target domain/URL.</small>
        </div>
      </div>
      <div class="modal-footer" style="border-top: 1px solid rgba(255,255,255,0.1); padding: 15px 20px;">
        <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-lp btn-lp-primary" onclick="PluginsPage.submitConfig()">Save</button>
      </div>
    </div>
  </div>
</div>

<script>
  const PluginsPage = (() => {
    let bsModal = null;

    async function loadData() {
      try {
        const res = await LP.get('/plugins');
        if (res?.success) {
          renderPlugins(res.data || []);
        }
      } catch (e) {
        console.error(e);
        LP.toast('Failed to load plugins', 'error');
      }
    }

    function renderPlugins(plugins) {
      const container = document.getElementById('pluginsContainer');
      container.innerHTML = plugins.map(p => `
        <div class="col-md-4 mb-4">
          <div class="lp-glass-card h-100 d-flex flex-column" style="padding:20px">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h5 style="margin:0;font-weight:600;color:var(--text-primary)"><i class="bi ${p.icon || 'bi-plugin'}" style="color:${p.color || '#38bdf8'}; margin-right:8px;"></i>${p.name}</h5>
              <span class="lp-badge lp-badge-info" style="font-size:11px">v${p.version}</span>
            </div>
            <p style="color:var(--text-muted);font-size:13px;flex-grow:1;margin-bottom:8px;">${p.description}</p>
            ${p.proxyUrl 
              ? `<div style="font-size:11px; color:#38bdf8; display:flex; align-items:center; gap:6px; margin-bottom:12px; background: rgba(56, 189, 248, 0.08); padding: 6px 10px; border-radius: 6px; border: 1px solid rgba(56, 189, 248, 0.15);">
                  <i class="bi bi-link-45deg" style="font-size: 14px;"></i> <span>Proxy: <strong>${p.proxyUrl}</strong></span>
                 </div>`
              : ''
            }
            <div class="d-flex justify-content-end" style="margin-top:15px">
              ${p.installed 
                ? `
                  <div class="d-flex gap-2 w-100">
                    <a href="${p.path}" target="${p.proxyUrl ? '_blank' : '_self'}" class="btn-lp btn-lp-primary flex-grow-1 text-center" style="text-decoration:none; display:inline-block; line-height:36px; height:36px; padding:0 12px; font-size:14px; font-weight:600; border-radius:8px;">Open</a>
                    <button class="btn-lp btn-lp-ghost text-light" style="height:36px; width:36px; display:flex; align-items:center; justify-content:center; padding:0; border-radius:8px;" onclick="PluginsPage.showConfigModal('${p.id}', '${p.name}', '${p.proxyUrl}', 'update')" title="Configure Proxy"><i class="bi bi-gear"></i></button>
                    <button class="btn-lp btn-lp-ghost text-danger" style="height:36px; width:36px; display:flex; align-items:center; justify-content:center; padding:0; border-radius:8px;" onclick="PluginsPage.uninstall('${p.id}')" title="Uninstall"><i class="bi bi-trash"></i></button>
                  </div>
                `
                : `<button class="btn-lp btn-lp-primary px-4" onclick="PluginsPage.showConfigModal('${p.id}', '${p.name}', '', 'install')">Install</button>`
              }
            </div>
          </div>
        </div>
      `).join('');
    }

    function showConfigModal(id, name, proxyUrl, mode) {
      document.getElementById('configPluginId').value = id;
      document.getElementById('configMode').value = mode;
      document.getElementById('configPluginName').value = name;
      document.getElementById('configProxyUrl').value = proxyUrl || '';
      document.getElementById('modalTitle').textContent = mode === 'install' ? `Install ${name}` : `Configure ${name}`;

      if (!bsModal) {
        bsModal = new bootstrap.Modal(document.getElementById('pluginConfigModal'));
      }
      bsModal.show();
    }

    async function submitConfig() {
      const id = document.getElementById('configPluginId').value;
      const mode = document.getElementById('configMode').value;
      const proxyUrl = document.getElementById('configProxyUrl').value;

      try {
        let res;
        if (mode === 'install') {
          res = await LP.post('/plugins/install', { id, proxyUrl });
        } else {
          res = await LP.post('/plugins/proxy', { id, proxyUrl });
        }

        if (res?.success) {
          LP.toast(res.message, 'success');
          if (bsModal) bsModal.hide();
          loadData();
        } else {
          LP.toast(res?.message || 'Action failed', 'error');
        }
      } catch (err) {
        LP.toast('Error submitting configuration', 'error');
      }
    }

    async function uninstall(id) {
      try {
        const res = await LP.post('/plugins/uninstall', { id });
        if (res?.success) {
          LP.toast(res.message, 'success');
          loadData();
        } else {
          LP.toast(res?.message || 'Failed to uninstall plugin', 'error');
        }
      } catch (err) {
        LP.toast('Uninstallation error', 'error');
      }
    }

    document.addEventListener('DOMContentLoaded', loadData);

    return { showConfigModal, submitConfig, uninstall };
  })();
</script>
