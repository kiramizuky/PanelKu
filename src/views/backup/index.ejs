<style>
  .bkp-tab {
    padding: 10px 20px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }
  .bkp-tab:hover {
    color: var(--text-primary);
    background: rgba(255,255,255,0.03);
  }
  .bkp-tab.active {
    color: var(--accent-primary);
    background: rgba(99,102,241,0.08);
    border-bottom-color: var(--accent-primary);
  }
  .bkp-tab-content {
    display: none;
  }
  .bkp-tab-content.active {
    display: block;
    animation: fadeIn 0.25s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;flex-wrap:wrap;gap:10px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">
      <i class="bi bi-cloud-arrow-up-fill text-warning me-2"></i> Backup &amp; Disaster Recovery
    </h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">
      Scheduled backups, Rclone cloud sync, S3 offsite storage, and disaster recovery
    </p>
  </div>
  <div style="display:flex;gap:8px;flex-wrap:wrap;">
    <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="BackupPage.refresh()" title="Refresh">
      <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>
  </div>
</div>

<!-- Status Cards -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="lp-glass-card p-3 d-flex align-items-center gap-3" style="border-left:3px solid var(--accent-warning);">
      <div style="width:40px;height:40px;border-radius:10px;background:rgba(245,158,11,0.12);display:flex;align-items:center;justify-content:center;font-size:20px;color:#f59e0b;">
        <i class="bi bi-cloud-arrow-up-fill"></i>
      </div>
      <div>
        <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;">Rclone</div>
        <div id="bkpRcloneStatus" style="font-size:16px;font-weight:700;color:var(--text-primary);">—</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="lp-glass-card p-3 d-flex align-items-center gap-3" style="border-left:3px solid var(--accent-info);">
      <div style="width:40px;height:40px;border-radius:10px;background:rgba(59,130,246,0.12);display:flex;align-items:center;justify-content:center;font-size:20px;color:#3b82f6;">
        <i class="bi bi-clock-history"></i>
      </div>
      <div>
        <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;">Jobs</div>
        <div id="bkpJobCount" style="font-size:16px;font-weight:700;color:var(--text-primary);">—</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="lp-glass-card p-3 d-flex align-items-center gap-3" style="border-left:3px solid var(--accent-success);">
      <div style="width:40px;height:40px;border-radius:10px;background:rgba(16,185,129,0.12);display:flex;align-items:center;justify-content:center;font-size:20px;color:#10b981;">
        <i class="bi bi-hdd-stack"></i>
      </div>
      <div>
        <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;">Local Backups</div>
        <div id="bkpLocalCount" style="font-size:16px;font-weight:700;color:var(--text-primary);">—</div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="lp-glass-card p-3 d-flex align-items-center gap-3" style="border-left:3px solid var(--accent-purple);">
      <div style="width:40px;height:40px;border-radius:10px;background:rgba(139,92,246,0.12);display:flex;align-items:center;justify-content:center;font-size:20px;color:#8b5cf6;">
        <i class="bi bi-shield-check"></i>
      </div>
      <div>
        <div style="font-size:10px;color:var(--text-muted);text-transform:uppercase;">S3 Ready</div>
        <div id="bkpS3Status" style="font-size:16px;font-weight:700;color:var(--text-primary);">—</div>
      </div>
    </div>
  </div>
</div>

<!-- Tabs -->
<div class="lp-glass-card mb-4" style="padding:0;overflow:hidden;">
  <div style="display:flex;border-bottom:1px solid var(--glass-border);overflow-x:auto;background:rgba(0,0,0,0.1);">
    <button class="bkp-tab active" data-tab="dashboard" onclick="BackupPage.switchTab('dashboard')">
      <i class="bi bi-speedometer2 me-1"></i> Overview
    </button>
    <button class="bkp-tab" data-tab="jobs" onclick="BackupPage.switchTab('jobs')">
      <i class="bi bi-clock-history me-1"></i> Backup Jobs
    </button>
    <button class="bkp-tab" data-tab="local" onclick="BackupPage.switchTab('local')">
      <i class="bi bi-hdd-stack me-1"></i> Local Backups
    </button>
    <button class="bkp-tab" data-tab="rclone" onclick="BackupPage.switchTab('rclone')">
      <i class="bi bi-cloud-arrow-up-fill me-1"></i> Rclone
    </button>
    <button class="bkp-tab" data-tab="s3" onclick="BackupPage.switchTab('s3')">
      <i class="bi bi-database-fill-gear me-1"></i> S3 / DR
    </button>
  </div>

  <!-- ════════════════════ Tab: Overview ════════════════════ -->
  <div id="tab-dashboard" class="bkp-tab-content active" style="padding:20px;">
    <div class="row g-4">
      <div class="col-12 col-md-6">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:16px;">
            <i class="bi bi-cloud-arrow-up-fill text-warning me-1"></i> Rclone Status
          </h6>
          <table class="lp-table" style="font-size:13px;">
            <tbody>
              <tr><td style="padding:5px 0;color:var(--text-muted);width:110px;">Installed</td><td id="ovRcloneInstalled" style="padding:5px 0;">—</td></tr>
              <tr><td style="padding:5px 0;color:var(--text-muted);">Version</td><td id="ovRcloneVersion" style="padding:5px 0;">—</td></tr>
              <tr><td style="padding:5px 0;color:var(--text-muted);">Remotes</td><td id="ovRcloneRemotes" style="padding:5px 0;">—</td></tr>
              <tr><td style="padding:5px 0;color:var(--text-muted);">Config Path</td><td id="ovRcloneConfig" style="padding:5px 0;font-size:11px;">—</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="col-12 col-md-6">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:16px;">
            <i class="bi bi-shield-check text-success me-1"></i> Backup Health
          </h6>
          <div id="ovBackupHealth">
            <div style="padding:20px;text-align:center;color:var(--text-muted);font-size:13px;">Loading...</div>
          </div>
        </div>
      </div>
      <div class="col-12">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:12px;">
            <i class="bi bi-clock-history text-info me-1"></i> Recent Backup Jobs
          </h6>
          <div id="ovRecentJobs" style="font-size:13px;">
            <div style="padding:15px;text-align:center;color:var(--text-muted);">Loading...</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ════════════════════ Tab: Backup Jobs ════════════════════ -->
  <div id="tab-jobs" class="bkp-tab-content" style="padding:20px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 style="font-size:15px;font-weight:600;color:var(--text-primary);margin:0;">
        <i class="bi bi-clock-history text-primary me-1"></i> Scheduled Backup Jobs
      </h5>
      <button class="btn-lp btn-lp-primary btn-sm" onclick="BackupPage.showCreateJobModal()">
        <i class="bi bi-plus-lg me-1"></i> New Job
      </button>
    </div>
    <div id="jobsListContainer">
      <div style="padding:20px;text-align:center;color:var(--text-muted);">
        <div class="spinner-border spinner-border-sm text-primary me-2"></div> Loading jobs...
      </div>
    </div>
  </div>

  <!-- ════════════════════ Tab: Local Backups ════════════════════ -->
  <div id="tab-local" class="bkp-tab-content" style="padding:20px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h5 style="font-size:15px;font-weight:600;color:var(--text-primary);margin:0;">
        <i class="bi bi-hdd-stack text-primary me-1"></i> Local Backup Files
      </h5>
      <div style="display:flex;gap:8px;">
        <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="BackupPage.showS3Modal()">
          <i class="bi bi-gear me-1"></i> S3 Settings
        </button>
        <button class="btn-lp btn-lp-primary btn-sm" onclick="BackupPage.showCreateLocalBackupModal()">
          <i class="bi bi-plus-lg me-1"></i> Create Backup
        </button>
      </div>
    </div>
    <div class="table-responsive">
      <table class="lp-table">
        <thead>
          <tr>
            <th>Filename</th>
            <th>Size</th>
            <th>Date Created</th>
            <th style="text-align:right">Actions</th>
          </tr>
        </thead>
        <tbody id="backupTableBody">
          <tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ════════════════════ Tab: Rclone ════════════════════ -->
  <div id="tab-rclone" class="bkp-tab-content" style="padding:20px;">
    <!-- Rclone Not Installed Banner -->
    <div id="rcloneNotInstalled" style="display:none;" class="mb-4">
      <div class="alert" style="background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2);border-radius:12px;padding:16px 20px;color:#f59e0b;">
        <div class="d-flex align-items-start gap-3">
          <i class="bi bi-exclamation-triangle-fill" style="font-size:20px;flex-shrink:0;"></i>
          <div>
            <strong>Rclone is not installed</strong>
            <p style="margin:6px 0 0 0;font-size:13px;color:var(--text-muted);">
              Rclone is required for cloud backup sync. Click below to install it automatically.
            </p>
            <button class="btn-lp btn-lp-primary btn-sm mt-2" onclick="BackupPage.installRclone()">
              <i class="bi bi-download me-1"></i> Install Rclone
            </button>
          </div>
        </div>
      </div>
    </div>

    <div id="rcloneContent">
      <div class="row g-4">
        <div class="col-12 col-md-5">
          <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
            <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:15px;">
              <i class="bi bi-list-task text-primary me-1"></i> Configured Remotes
            </h6>
            <div id="rcloneRemotesList">
              <div style="padding:15px;text-align:center;color:var(--text-muted);font-size:13px;">Loading...</div>
            </div>
            <hr style="border-color:var(--glass-border);margin:15px 0;">
            <p style="font-size:11px;color:var(--text-muted);margin:0;">
              <i class="bi bi-info-circle me-1"></i> Manage remotes via terminal:
              <code class="font-mono" style="display:block;margin-top:4px;padding:6px 10px;background:rgba(0,0,0,0.2);border-radius:6px;">rclone config</code>
            </p>
          </div>
        </div>
        <div class="col-12 col-md-7">
          <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
            <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:15px;">
              <i class="bi bi-cloud-download text-info me-1"></i> Remote File Browser
            </h6>
            <div class="d-flex gap-2 mb-3">
              <select id="rcloneBrowseRemote" class="lp-input" style="width:160px;">
                <option value="">Select remote...</option>
              </select>
              <input type="text" id="rcloneBrowsePath" class="lp-input font-mono" style="flex:1;" placeholder="path (e.g. backups)" value="backups">
              <button class="btn-lp btn-lp-primary btn-sm" onclick="BackupPage.browseRemote()">
                <i class="bi bi-search me-1"></i> Browse
              </button>
            </div>
            <div id="rcloneBrowseResults" style="font-size:12px;max-height:300px;overflow-y:auto;">
              <div style="padding:15px;text-align:center;color:var(--text-muted);font-size:13px;">Select a remote and browse</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ════════════════════ Tab: S3 / Disaster Recovery ════════════════════ -->
  <div id="tab-s3" class="bkp-tab-content" style="padding:20px;">
    <div class="row g-4">
      <!-- S3 Config -->
      <div class="col-12 col-md-6">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:15px;">
            <i class="bi bi-database-fill-gear text-primary me-1"></i> S3 Configuration
          </h6>
          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" id="s3Enabled" onchange="BackupPage.toggleS3Fields()">
            <label class="form-check-label text-white" for="s3Enabled" style="margin-left:8px;">Enable S3 Offsite Backup</label>
          </div>
          <div class="lp-form-group mb-2">
            <label class="lp-label">Endpoint URL <span style="color:var(--text-muted);font-weight:400;">(optional, e.g. MinIO/Cloudflare R2)</span></label>
            <input type="text" id="s3Endpoint" class="lp-input font-mono" placeholder="https://s3.example.com">
          </div>
          <div class="lp-form-group mb-2">
            <label class="lp-label">Region</label>
            <input type="text" id="s3Region" class="lp-input" placeholder="us-east-1" value="us-east-1">
          </div>
          <div class="lp-form-group mb-2">
            <label class="lp-label">Bucket Name</label>
            <input type="text" id="s3Bucket" class="lp-input font-mono" placeholder="panelku-backups">
          </div>
          <div class="lp-form-group mb-2">
            <label class="lp-label">Access Key ID</label>
            <input type="text" id="s3AccessKey" class="lp-input font-mono" placeholder="AKIA...">
          </div>
          <div class="lp-form-group mb-3">
            <label class="lp-label">Secret Access Key</label>
            <input type="password" id="s3SecretKey" class="lp-input font-mono" placeholder="••••••••">
          </div>
          <div style="display:flex;gap:8px;">
            <button class="btn-lp btn-lp-primary" onclick="BackupPage.saveS3Config()" style="flex:1;">
              <i class="bi bi-floppy me-1"></i> Save
            </button>
            <button class="btn-lp btn-lp-ghost" onclick="BackupPage.testS3Connection()">
              <i class="bi bi-lightning-fill me-1"></i> Test
            </button>
          </div>
        </div>
      </div>

      <!-- Disaster Recovery -->
      <div class="col-12 col-md-6">
        <div class="lp-glass-card p-4" style="background:rgba(0,0,0,0.08);">
          <h6 style="font-size:13px;font-weight:600;color:var(--text-muted);margin-bottom:15px;">
            <i class="bi bi-shield-exclamation text-danger me-1"></i> Disaster Recovery
          </h6>

          <!-- S3 Backups -->
          <div class="mb-4">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <label class="lp-label" style="margin:0;">S3 Remote Backups</label>
              <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="BackupPage.loadS3Backups()">
                <i class="bi bi-arrow-clockwise"></i> Refresh
              </button>
            </div>
            <div id="s3BackupsList" style="max-height:180px;overflow-y:auto;font-size:12px;">
              <div style="padding:10px;text-align:center;color:var(--text-muted);">Configure S3 above and click refresh</div>
            </div>
          </div>

          <!-- Remote DR Restore -->
          <div>
            <label class="lp-label">Restore from Cloud Remote</label>
            <div class="d-flex gap-2 mb-2">
              <select id="drRemoteSelect" class="lp-input" style="width:140px;">
                <option value="">Remote...</option>
              </select>
              <input type="text" id="drRemotePath" class="lp-input font-mono" style="flex:1;" placeholder="remote path (e.g. backups/db)" value="backups">
              <button class="btn-lp btn-lp-ghost btn-lp-sm" onclick="BackupPage.loadDRBackups()">
                <i class="bi bi-search"></i>
              </button>
            </div>
            <div id="drRestoreList" style="max-height:150px;overflow-y:auto;font-size:12px;">
              <div style="padding:10px;text-align:center;color:var(--text-muted);">Select remote and click search</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ── Create Backup Job Modal ── -->
<div class="modal fade" id="createJobModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border:1px solid rgba(255,255,255,0.1);background:rgba(20,20,25,0.95);">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);">
        <h5 class="modal-title font-mono text-white" style="font-size:15px;">
          <i class="bi bi-plus-circle text-primary me-2"></i> Create Backup Job
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="lp-form-group mb-2">
          <label class="lp-label">Job Name</label>
          <input type="text" id="cjName" class="lp-input" placeholder="e.g. Daily Website Backup" required>
        </div>
        <div class="lp-form-group mb-2">
          <label class="lp-label">Source Directory (Local Path)</label>
          <input type="text" id="cjSource" class="lp-input font-mono" placeholder="/var/www/example.com" required>
        </div>
        <div class="lp-form-group mb-2">
          <label class="lp-label">Rclone Remote Destination</label>
          <select id="cjRemote" class="lp-input" required>
            <option value="">Loading remotes...</option>
          </select>
        </div>
        <div class="lp-form-group mb-2">
          <label class="lp-label">Destination Path (on Remote)</label>
          <input type="text" id="cjDestPath" class="lp-input font-mono" placeholder="backups/my-site" value="backups">
        </div>
        <div class="lp-form-group mb-2">
          <label class="lp-label">Sync Type</label>
          <select id="cjType" class="lp-input">
            <option value="sync">Sync (mirror — deletes extra files at destination)</option>
            <option value="copy">Copy (append only — keeps old files)</option>
          </select>
        </div>
        <div class="lp-form-group mb-2">
          <label class="lp-label">Cron Schedule</label>
          <input type="text" id="cjSchedule" class="lp-input font-mono" placeholder="0 2 * * *" value="0 2 * * *">
          <div style="font-size:11px;color:var(--text-muted);margin-top:2px;">Default: daily at 2 AM</div>
        </div>
        <div class="lp-form-group mb-2">
          <label class="lp-label">Retention (number of backup copies to keep, 0 = unlimited)</label>
          <input type="number" id="cjRetention" class="lp-input" placeholder="7" value="7" min="0" max="365">
        </div>
        <div class="lp-form-group">
          <label class="lp-label">Exclude Patterns (one per line)</label>
          <textarea id="cjExclude" class="lp-input font-mono" rows="2" placeholder="node_modules&#10;.git&#10;*.log" style="resize:vertical;"></textarea>
        </div>
      </div>
      <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);">
        <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-lp btn-lp-primary" onclick="BackupPage.createJob()">
          <i class="bi bi-plus-lg me-1"></i> Create
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ── Create Local Backup Modal ── -->
<div class="modal fade" id="createLocalBackupModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content lp-glass-card" style="border:1px solid rgba(255,255,255,0.1);background:rgba(20,20,25,0.95);">
      <div class="modal-header" style="border-bottom:1px solid rgba(255,255,255,0.1);">
        <h5 class="modal-title font-mono text-white" style="font-size:15px;">
          <i class="bi bi-plus-circle text-primary me-2"></i> Create Local Backup
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="lp-form-group mb-3">
          <label class="lp-label">Backup Type</label>
          <select id="lbType" class="lp-input">
            <option value="mysql">MySQL Database</option>
            <option value="postgres">PostgreSQL Database</option>
            <option value="files">Website Files</option>
            <option value="panel">Full Panel (DB + Config)</option>
          </select>
        </div>
        <div class="lp-form-group mb-3">
          <label class="lp-label">Target Name</label>
          <input type="text" id="lbTarget" class="lp-input font-mono" placeholder="database_name or domain" required>
          <div style="font-size:11px;color:var(--text-muted);margin-top:4px;">For files: folder name inside /var/www. For panel: leave as-is.</div>
        </div>
      </div>
      <div class="modal-footer" style="border-top:1px solid rgba(255,255,255,0.1);">
        <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn-lp btn-lp-primary" onclick="BackupPage.createLocalBackup()">
          <i class="bi bi-cloud-arrow-up me-1"></i> Create
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ── Job Run Log Modal ── -->
<div class="modal fade" id="jobLogModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
