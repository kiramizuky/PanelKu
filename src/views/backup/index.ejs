<div class="lp-page-header" style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:20px;">
  <div>
    <h1 class="lp-page-title" style="font-size:24px;font-weight:600;margin:0;">Local Backups</h1>
    <p class="lp-page-subtitle" style="color:var(--text-muted);margin:0;">Backup your databases and website files</p>
  </div>
  <div style="display:flex;gap:10px">
    <button class="btn-lp btn-lp-ghost" onclick="BackupPage.showS3Modal()"><i class="bi bi-gear"></i> S3 Settings</button>
    <button class="btn-lp btn-lp-primary" onclick="BackupPage.showCreateModal()"><i class="bi bi-cloud-arrow-down"></i> Create Backup</button>
  </div>
</div>

<div class="lp-glass-card" style="padding:0;overflow-x:auto;">
  <table class="lp-table">
    <thead>
      <tr>
        <th>Filename</th>
        <th>Size</th>
        <th>Date Created</th>
        <th style="text-align:right">Actions</th>
      </tr>
    </thead>
    <tbody id="backupTableBody">
      <tr><td colspan="4" style="text-align:center;padding:20px;color:var(--text-muted)">Loading...</td></tr>
    </tbody>
  </table>
  <div id="backupPagination" style="padding: 0 15px 15px 15px;"></div>
</div>

<!-- Create Modal -->
<div class="modal fade" id="createBackupModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px">Create New Backup</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="createBackupForm" onsubmit="BackupPage.createBackup(event)">
        <div class="modal-body">
          <div class="lp-form-group">
            <label class="lp-label">Backup Type</label>
            <select id="backupType" class="lp-input" required>
              <option value="mysql">MySQL Database</option>
              <option value="postgres">PostgreSQL Database</option>
              <option value="files">Website Files / Folder</option>
            </select>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Target Name / Path</label>
            <input type="text" id="backupTarget" class="lp-input" placeholder="e.g. database_name or example.com" required>
            <small class="text-muted" style="font-size:11px; margin-top:4px; display:block;">For files, specify the folder name inside /var/www</small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary" id="btnCreateBackup">Create Backup</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Restore Modal -->
<div class="modal fade" id="restoreBackupModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px">Restore Backup</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="restoreBackupForm" onsubmit="BackupPage.restoreBackup(event)">
        <div class="modal-body">
          <div class="lp-form-group">
            <label class="lp-label">Filename</label>
            <input type="text" id="restoreFilename" class="lp-input" readonly>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Target Database / Directory Path</label>
            <input type="text" id="restoreTarget" class="lp-input" placeholder="e.g. database_name or /var/www/example.com" required>
            <small class="text-muted" style="font-size:11px; margin-top:4px; display:block;">Be very careful! Existing data may be overwritten.</small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary" id="btnRestoreBackup">Restore Backup</button>
        </div>
      </form>
    </div>
  </div>
<!-- S3 Configuration Modal -->
<div class="modal fade" id="s3ConfigModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title font-mono" style="font-size:14px">S3 Backup Configuration</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="s3ConfigForm" onsubmit="BackupPage.saveS3Config(event)">
        <div class="modal-body">
          <div class="form-check form-switch mb-3">
            <input class="form-check-input" type="checkbox" id="s3Enabled">
            <label class="form-check-label text-white" for="s3Enabled" style="margin-left: 10px;">Enable Upload to S3 Destination</label>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">S3 Endpoint URL (Optional)</label>
            <input type="text" id="s3Endpoint" class="lp-input" placeholder="e.g. https://<id>.r2.cloudflarestorage.com or MinIO endpoint">
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Region</label>
            <input type="text" id="s3Region" class="lp-input" placeholder="e.g. us-east-1" value="us-east-1">
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Bucket Name</label>
            <input type="text" id="s3Bucket" class="lp-input" placeholder="e.g. panelku-backups" required>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Access Key ID</label>
            <input type="text" id="s3AccessKey" class="lp-input" placeholder="Access key ID" required>
          </div>
          <div class="lp-form-group">
            <label class="lp-label">Secret Access Key</label>
            <input type="password" id="s3SecretKey" class="lp-input" placeholder="Secret access key" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-lp btn-lp-ghost" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn-lp btn-lp-primary">Save Settings</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/backup.js"></script>
