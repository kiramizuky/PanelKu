# ========================
# Linux Panel — .env config
# ========================

# App
NODE_ENV=development
PORT=23456
APP_NAME=Panelku
APP_URL=http://localhost:23456
APP_SECRET=change_this_to_a_very_long_random_secret_string

# JWT
JWT_SECRET=change_this_jwt_secret_very_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_very_long_random
JWT_REFRESH_EXPIRES_IN=7d

# SQLite Database
DB_PATH=./storage/panelku.db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Session
SESSION_COOKIE_NAME=lp_session
SESSION_MAX_AGE=604800000

# 2FA
TOTP_ISSUER=Panelku

# Upload
UPLOAD_MAX_SIZE=104857600
UPLOAD_PATH=./storage/uploads

# Backup Storage
BACKUP_PATH=./storage/backups

# Logs
LOG_LEVEL=info
LOG_PATH=./storage/logs

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# External Databases Credentials
DB_MYSQL_HOST=localhost
DB_MYSQL_USER=root
DB_MYSQL_PASSWORD=
DB_PG_HOST=localhost
DB_PG_USER=postgres
DB_PG_PASSWORD=
