    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dockerode": "^5.0.1",
    "dotenv": "^16.4.7",
    "ejs": "^6.0.1",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
